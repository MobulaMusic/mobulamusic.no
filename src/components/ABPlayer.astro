---
import type { Referanse } from '../lib/content';
interface Props { referanser: Referanse[]; }
const { referanser } = Astro.props;
---
<div class="space-y-6">
  {referanser.map((r, i) => (
    <div
      class="ab-player bg-dark-card border border-dark-border/60 rounded-2xl p-6"
      data-ab={i}
      data-raw={r.rawSrc}
      data-mixed={r.mixedSrc}
    >
      <div class="mb-4">
        <h3 class="font-serif text-xl font-semibold mb-1">{r.title}</h3>
        {r.description && <p class="text-cream/70 text-sm">{r.description}</p>}
      </div>

      <div class="flex items-center gap-4">
        <button
          type="button"
          class="ab-play w-12 h-12 rounded-full bg-gold text-dark flex items-center justify-center shrink-0 hover:bg-gold-light transition-colors"
          aria-label="Spill av"
        >
          <svg class="ab-play-svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          <svg class="ab-pause-svg hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
        </button>

        <div class="flex-1 min-w-0">
          <div class="ab-seek h-1.5 bg-cream/10 rounded-full cursor-pointer relative" role="slider">
            <div class="ab-progress h-full bg-gold rounded-full" style="width: 0%"></div>
          </div>
          <div class="flex justify-between text-xs text-cream/40 font-mono mt-1.5 tabular-nums">
            <span class="ab-time">0:00</span>
            <span class="ab-duration">0:00</span>
          </div>
        </div>

        <div class="flex rounded-lg overflow-hidden border border-dark-border shrink-0" role="tablist">
          <button type="button" class="ab-toggle px-3 py-2 text-xs font-medium bg-cream/5 text-cream/60 hover:bg-cream/10 transition-colors active:text-cream" data-variant="raw">
            {r.rawLabel || 'Rå'}
          </button>
          <button type="button" class="ab-toggle px-3 py-2 text-xs font-medium bg-gold text-dark" data-variant="mixed">
            {r.mixedLabel || 'Mikset'}
          </button>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  function formatTime(s: number) {
    if (!isFinite(s)) return '0:00';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  document.querySelectorAll<HTMLElement>('.ab-player').forEach((el) => {
    const rawSrc = el.dataset.raw!;
    const mixedSrc = el.dataset.mixed!;
    // Preload both so swapping is instant and position-preserved.
    const rawAudio = new Audio(rawSrc);
    const mixedAudio = new Audio(mixedSrc);
    rawAudio.preload = 'auto';
    mixedAudio.preload = 'auto';

    let active: HTMLAudioElement = mixedAudio;
    let playing = false;

    const playBtn = el.querySelector<HTMLButtonElement>('.ab-play')!;
    const playSvg = el.querySelector<SVGElement>('.ab-play-svg')!;
    const pauseSvg = el.querySelector<SVGElement>('.ab-pause-svg')!;
    const seek = el.querySelector<HTMLElement>('.ab-seek')!;
    const progress = el.querySelector<HTMLElement>('.ab-progress')!;
    const timeEl = el.querySelector<HTMLElement>('.ab-time')!;
    const durEl = el.querySelector<HTMLElement>('.ab-duration')!;
    const toggles = el.querySelectorAll<HTMLButtonElement>('.ab-toggle');

    function updatePlayIcon() {
      playSvg.classList.toggle('hidden', playing);
      pauseSvg.classList.toggle('hidden', !playing);
    }
    function update() {
      const d = active.duration || 0;
      const t = active.currentTime || 0;
      progress.style.width = d > 0 ? `${(t / d) * 100}%` : '0%';
      timeEl.textContent = formatTime(t);
      durEl.textContent = formatTime(d);
    }
    [rawAudio, mixedAudio].forEach((a) => {
      a.addEventListener('timeupdate', () => { if (a === active) update(); });
      a.addEventListener('loadedmetadata', () => { if (a === active) update(); });
      a.addEventListener('ended', () => {
        playing = false;
        updatePlayIcon();
      });
    });

    playBtn.addEventListener('click', () => {
      if (playing) {
        active.pause();
        playing = false;
      } else {
        active.play();
        playing = true;
      }
      updatePlayIcon();
    });

    seek.addEventListener('click', (e) => {
      const rect = seek.getBoundingClientRect();
      const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      const d = active.duration || 0;
      const t = ratio * d;
      active.currentTime = t;
      // Keep the other variant in sync for seamless A/B.
      const other = active === rawAudio ? mixedAudio : rawAudio;
      if (isFinite(other.duration)) other.currentTime = Math.min(t, other.duration);
      update();
    });

    toggles.forEach((tog) => {
      tog.addEventListener('click', () => {
        const variant = tog.dataset.variant;
        const next = variant === 'raw' ? rawAudio : mixedAudio;
        if (next === active) return;
        const t = active.currentTime;
        const wasPlaying = playing;
        active.pause();
        next.currentTime = isFinite(next.duration) ? Math.min(t, next.duration) : t;
        active = next;
        if (wasPlaying) active.play();
        toggles.forEach((b) => {
          const isActive = b === tog;
          b.classList.toggle('bg-gold', isActive);
          b.classList.toggle('text-dark', isActive);
          b.classList.toggle('bg-cream/5', !isActive);
          b.classList.toggle('text-cream/60', !isActive);
        });
        update();
      });
    });
  });
</script>
