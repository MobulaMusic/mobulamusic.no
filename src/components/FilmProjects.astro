---
import type { FilmProject } from '../lib/content';
interface Props { projects: FilmProject[]; }
const { projects } = Astro.props;

function toEmbedUrl(url: string): string | null {
  try {
    const u = new URL(url);
    const host = u.hostname.replace(/^www\./, '');
    if (host === 'youtube.com' || host === 'm.youtube.com') {
      const id = u.searchParams.get('v');
      if (id) return `https://www.youtube.com/embed/${id}?rel=0`;
      if (u.pathname.startsWith('/embed/')) return url;
    }
    if (host === 'youtu.be') {
      const id = u.pathname.slice(1);
      if (id) return `https://www.youtube.com/embed/${id}?rel=0`;
    }
    if (host === 'vimeo.com') {
      const id = u.pathname.split('/').filter(Boolean)[0];
      if (id && /^\d+$/.test(id)) return `https://player.vimeo.com/video/${id}`;
    }
    if (host === 'player.vimeo.com') return url;
    return null;
  } catch {
    return null;
  }
}

const CREW: { key: keyof FilmProject; label: string }[] = [
  { key: 'director', label: 'Regi' },
  { key: 'producer', label: 'Produsent' },
  { key: 'composer', label: 'Komponist' },
  { key: 'editor', label: 'Klipp' },
  { key: 'soundDesign', label: 'Lyddesign' },
  { key: 'photo', label: 'Foto' },
  { key: 'sound', label: 'Lyd' },
  { key: 'postProduction', label: 'Postproduksjon' },
];
---
<div class="space-y-12">
  {projects.map((project, pi) => {
    const embedUrl = project.videoUrl ? toEmbedUrl(project.videoUrl) : null;
    return (
    <article class="bg-dark-card border border-dark-border/60 rounded-2xl overflow-hidden" data-film-project={pi}>
      {embedUrl && (
        <div class="aspect-video w-full bg-black">
          <iframe
            src={embedUrl}
            title={project.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          />
        </div>
      )}
      <div class:list={["md:flex", embedUrl && 'md:block']}>
        {!embedUrl && (
          <div class="md:w-[320px] md:shrink-0 relative bg-dark">
            <div class="aspect-[2/3] md:aspect-auto md:absolute md:inset-0 overflow-hidden">
              {project.poster ? (
                <>
                  <img
                    src={project.poster}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover scale-110 blur-2xl opacity-40"
                  />
                  <div class="absolute inset-0 bg-gradient-to-b from-dark/30 via-transparent to-dark/40"></div>
                  <img
                    src={project.poster}
                    alt={project.title}
                    loading="lazy"
                    class="relative w-full h-full object-contain p-4"
                  />
                </>
              ) : (
                <div class="w-full h-full bg-cream/5 flex items-center justify-center">
                  <span class="text-cream/20 text-xs uppercase tracking-wider">Film</span>
                </div>
              )}
            </div>
          </div>
        )}

        <div class="p-6 md:p-8 flex flex-col flex-1 min-w-0">
          <div class="mb-3">
            <h3 class="font-serif text-2xl font-semibold mb-1">{project.title}</h3>
            <p class="text-gold text-sm">
              {project.role}{project.year && <> &middot; {project.year}</>}
            </p>
          </div>

          {project.description && (
            <p class="text-cream/70 text-sm leading-relaxed mb-5">{project.description}</p>
          )}

          {CREW.some(f => project[f.key]) && (
            <div class="mb-5 border-t border-dark-border/60 pt-4">
              <p class="text-cream/50 text-xs uppercase tracking-wider mb-3">Medvirkende</p>
              <div class="grid gap-1.5 text-sm">
                {CREW.filter(f => project[f.key]).map(f => (
                  <div class="flex">
                    <span class="text-cream/50 w-32 shrink-0">{f.label}</span>
                    <span>{project[f.key]}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {project.tracks && project.tracks.length > 0 && (
            <div class="mt-auto">
              <p class="text-cream/50 text-xs uppercase tracking-wider mb-2">Lydeksempler</p>
              <div class="divide-y divide-dark-border/60 rounded-lg overflow-hidden border border-dark-border/40">
                {project.tracks.map((track, ti) => (
                  <button
                    type="button"
                    class="film-track w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-cream/[0.03] transition-colors"
                    data-project={pi}
                    data-track={ti}
                    data-src={track.src}
                  >
                    <span class="text-cream/40 text-xs w-6 text-right shrink-0 font-mono">{String(ti + 1).padStart(2, '0')}</span>
                    <span class="play-icon w-8 h-8 rounded-full flex items-center justify-center shrink-0">
                      <svg class="play-svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                      <svg class="pause-svg hidden" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" /><rect x="14" y="4" width="4" height="16" /></svg>
                    </span>
                    <span class="flex-1 min-w-0 text-sm truncate">{track.title}</span>
                    {track.duration && <span class="text-cream/40 text-xs font-mono">{track.duration}</span>}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </article>
    );
  })}
</div>

<script>
  let audio: HTMLAudioElement | null = null;
  let currentBtn: HTMLButtonElement | null = null;

  function resetBtn(btn: HTMLButtonElement | null) {
    if (!btn) return;
    btn.querySelector('.play-svg')?.classList.remove('hidden');
    btn.querySelector('.pause-svg')?.classList.add('hidden');
    btn.querySelector('.play-icon')?.classList.remove('text-gold');
  }
  function setPlaying(btn: HTMLButtonElement) {
    btn.querySelector('.play-svg')?.classList.add('hidden');
    btn.querySelector('.pause-svg')?.classList.remove('hidden');
    btn.querySelector('.play-icon')?.classList.add('text-gold');
  }

  document.querySelectorAll<HTMLButtonElement>('.film-track').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src!;
      if (currentBtn === btn && audio && !audio.paused) {
        audio.pause();
        resetBtn(btn);
        return;
      }
      if (audio) { audio.pause(); resetBtn(currentBtn); }
      audio = new Audio(src);
      audio.addEventListener('ended', () => resetBtn(btn));
      audio.play();
      currentBtn = btn;
      setPlaying(btn);
    });
  });
</script>
