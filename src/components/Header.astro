---
const navLinks = [
  { href: '/innspilling', label: 'Innspilling' },
  { href: '/podkast', label: 'Podkast' },
  { href: '/komposisjon', label: 'Komposisjon' },
  { href: '/om-oss', label: 'Om oss' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img src="/images/logo/mobula-logo.jpg" alt="Mobula Music" class="h-10 w-10 rounded-full object-cover" />
      <span class="text-lg font-semibold tracking-wide text-cream hidden sm:block">MOBULA MUSIC</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium tracking-wide uppercase transition-colors duration-200 hover:text-gold',
            currentPath.startsWith(link.href) ? 'text-gold' : 'text-cream/80',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/kontakt"
        class="ml-4 px-5 py-2.5 bg-gold text-dark text-sm font-semibold rounded tracking-wide uppercase hover:bg-gold-light transition-colors duration-200"
      >
        Kontakt oss
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-cream p-2"
      aria-label="Meny"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-dark-light/95 backdrop-blur-md border-t border-dark-border">
    <div class="px-6 py-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-base font-medium tracking-wide uppercase py-2 transition-colors',
            currentPath.startsWith(link.href) ? 'text-gold' : 'text-cream/80 hover:text-gold',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/kontakt"
        class="mt-2 px-5 py-3 bg-gold text-dark text-sm font-semibold rounded tracking-wide uppercase text-center hover:bg-gold-light transition-colors"
      >
        Kontakt oss
      </a>
    </div>
  </div>
</header>

<script>
  // Scroll behavior: transparent → solid background
  const header = document.getElementById('site-header')!;
  const onScroll = () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
    } else {
      header.classList.remove('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
    }
  };
  window.addEventListener('scroll', onScroll);
  onScroll();

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const menuIcon = document.getElementById('menu-icon')!;
  const closeIcon = document.getElementById('close-icon')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
    if (!isOpen) {
      header.classList.add('bg-dark/95', 'backdrop-blur-md');
    }
  });

  // Close mobile menu on link click
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menuIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    });
  });
</script>
