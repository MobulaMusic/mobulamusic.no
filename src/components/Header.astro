---
import Mobula from './Mobula.astro';

interface Props { altLang?: string }
const { altLang } = Astro.props;

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en');

// Map between language versions so the language-switch button preserves context.
// Keys are the non-prefixed path; values are the alternate-language equivalent.
const pathMap: Record<string, string> = {
  '/': '/en',
  '/innspilling': '/en/recording',
  '/innspilling/singer-songwriter': '/en/recording/singer-songwriter',
  '/innspilling/vokal': '/en/recording/vocal',
  '/innspilling/lydbok-og-voice-over': '/en/recording/voice-over-and-audiobook',
  '/innspilling/band-og-ensemble': '/en/recording/band-and-ensemble',
  '/innspilling/strykere-og-klassisk': '/en/recording/strings-and-classical',
  '/podkast': '/en/podcast',
  '/musikk': '/en/music',
  '/musikk/film-og-tv': '/en/music/film-and-tv',
  '/musikk/produsering': '/en/music/production',
  '/musikk/reklame-og-event': '/en/music/advertising-and-events',
  '/musikk/scenekunst-og-teater': '/en/music/stage-and-theatre',
  '/musikk/noter-for-daw': '/en/music/score-preparation',
  '/priser': '/en/pricing',
  '/om-oss': '/en/about',
  '/kontakt': '/en/contact',
  '/timeleie': '/en/rental',
  '/personvern': '/en/privacy',
  '/nyheter': '/nyheter',
};
const reverseMap: Record<string, string> = Object.fromEntries(
  Object.entries(pathMap).map(([no, en]) => [en, no])
);

function resolveSwitch(): string {
  if (altLang) return altLang;
  const cleaned = currentPath.replace(/\/$/, '') || '/';
  if (isEn) return reverseMap[cleaned] || '/';
  return pathMap[cleaned] || '/en';
}
const langSwitchHref = resolveSwitch();

const navLinks = isEn
  ? [
      { href: '/en/recording', label: 'Recording' },
      { href: '/en/podcast', label: 'Podcast' },
      { href: '/en/music', label: 'Music' },
      { href: '/en/pricing', label: 'Pricing' },
      { href: '/en/about', label: 'About' },
    ]
  : [
      { href: '/innspilling', label: 'Innspilling' },
      { href: '/podkast', label: 'Podkast' },
      { href: '/musikk', label: 'Musikk' },
      { href: '/priser', label: 'Priser' },
      { href: '/om-oss', label: 'Om oss' },
    ];

const contactHref = isEn ? '/en/contact' : '/kontakt';
const contactLabel = isEn ? 'Get in touch' : 'Kontakt oss';
const langSwitchLabel = isEn ? 'NO' : 'EN';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Mobula Music">
      <Mobula class="h-9 w-auto transition-transform duration-300 group-hover:scale-105" c1="#1f8e6e" c2="#7af0c8" c3="#c4f9e2" />
      <span class="text-lg font-semibold tracking-wide text-cream hidden sm:block">MOBULA MUSIC</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium tracking-wide uppercase transition-colors duration-200 hover:text-gold',
            currentPath.startsWith(link.href) ? 'text-gold' : 'text-cream/90',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={langSwitchHref}
        data-lang-switch
        class="text-xs font-mono tracking-widest text-cream/60 hover:text-gold transition-colors duration-200"
        aria-label={`Switch to ${langSwitchLabel === 'EN' ? 'English' : 'Norwegian'}`}
      >
        {langSwitchLabel}
      </a>
      <a
        href={contactHref}
        class="ml-2 px-5 py-2.5 bg-gold text-dark text-sm font-semibold rounded tracking-wide uppercase hover:bg-gold-light transition-colors duration-200"
      >
        {contactLabel}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-cream p-2"
      aria-label="Meny"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-dark-light/95 backdrop-blur-md border-t border-dark-border">
    <div class="px-6 py-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-base font-medium tracking-wide uppercase py-2 transition-colors',
            currentPath.startsWith(link.href) ? 'text-gold' : 'text-cream/90 hover:text-gold',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={contactHref}
        class="mt-2 px-5 py-3 bg-gold text-dark text-sm font-semibold rounded tracking-wide uppercase text-center hover:bg-gold-light transition-colors"
      >
        {contactLabel}
      </a>
      <a
        href={langSwitchHref}
        data-lang-switch
        class="mt-2 text-center text-xs font-mono tracking-widest text-cream/60 hover:text-gold transition-colors py-2"
      >
        {langSwitchLabel === 'EN' ? 'English version' : 'Norsk versjon'}
      </a>
    </div>
  </div>
</header>

<script>
  // Preserve scroll position across language switch.
  // Store scroll as a ratio (0–1) of the document height so it works
  // even if the translated page is a different total length.
  const SCROLL_KEY = 'mobula_lang_switch_scroll_ratio';
  document.querySelectorAll<HTMLAnchorElement>('a[data-lang-switch]').forEach((a) => {
    a.addEventListener('click', () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = docHeight > 0 ? window.scrollY / docHeight : 0;
      sessionStorage.setItem(SCROLL_KEY, String(ratio));
    });
  });
  const savedRatio = sessionStorage.getItem(SCROLL_KEY);
  if (savedRatio !== null) {
    sessionStorage.removeItem(SCROLL_KEY);
    const restore = () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      window.scrollTo({ top: Math.round(parseFloat(savedRatio) * docHeight), behavior: 'instant' as ScrollBehavior });
    };
    // Wait for layout so scrollHeight is accurate, including lazy-loaded images.
    if (document.readyState === 'complete') requestAnimationFrame(restore);
    else window.addEventListener('load', () => requestAnimationFrame(restore));
  }

  // Scroll behavior: transparent → solid background
  const header = document.getElementById('site-header')!;
  const onScroll = () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
    } else {
      header.classList.remove('bg-dark/95', 'backdrop-blur-md', 'shadow-lg');
    }
  };
  window.addEventListener('scroll', onScroll);
  onScroll();

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const menuIcon = document.getElementById('menu-icon')!;
  const closeIcon = document.getElementById('close-icon')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
    if (!isOpen) {
      header.classList.add('bg-dark/95', 'backdrop-blur-md');
    }
  });

  // Close mobile menu on link click
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menuIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    });
  });
</script>
