---
interface Props {
  title?: string;
  intro?: string;
  items: string[];
  class?: string;
}

const {
  title = 'Passer for deg uansett',
  intro = 'Studio kan virke skummelt første gang. Det trenger det ikke å være.',
  items,
  class: className = '',
} = Astro.props;
---

<section class={`relative py-20 px-6 ${className}`}>
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-start md:gap-16 gap-8 fade-in">
      <div class="md:w-2/5">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Velkommen</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-tight mb-4">{title}</h2>
        <p class="text-cream/75 text-base leading-relaxed">{intro}</p>
      </div>

      <ul class="md:w-3/5 space-y-5">
        {items.map((item) => (
          <li class="flex items-start gap-4 pb-5 border-b border-cream/10 last:border-b-0">
            <span class="shrink-0 mt-2 w-2 h-2 rounded-full bg-gold" aria-hidden="true"></span>
            <span class="text-cream/90 text-base md:text-lg leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
