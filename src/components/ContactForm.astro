---
interface Props {
  formName: string;
  serviceType?: string;
  showServiceDropdown?: boolean;
  heading?: string;
  description?: string;
  lang?: 'no' | 'en';
}

const {
  formName,
  serviceType,
  showServiceDropdown = false,
  heading,
  description,
  lang = 'no',
} = Astro.props;

const t = lang === 'en'
  ? {
      heading: 'Get in touch',
      description: 'Fill out the form and we\'ll get back to you shortly.',
      firstName: 'First name',
      firstNamePlaceholder: 'Your first name',
      lastName: 'Last name',
      lastNamePlaceholder: 'Your last name',
      email: 'Email',
      emailPlaceholder: 'you@example.com',
      phone: 'Phone',
      phonePlaceholder: '+47 000 00 000',
      service: 'What is your inquiry about?',
      selectService: 'Select a service',
      message: 'Your message',
      messagePlaceholder: 'Tell us about your project...',
      submit: 'Send',
      sending: 'Sending...',
      success: 'Thanks for your message! We\'ll be in touch soon.',
      error: 'Something went wrong. Please try again or email post@mobulamusic.com.',
    }
  : {
      heading: 'Ta kontakt',
      description: 'Fyll ut skjemaet, så hører du fra oss innen kort tid.',
      firstName: 'Fornavn',
      firstNamePlaceholder: 'Ditt fornavn',
      lastName: 'Etternavn',
      lastNamePlaceholder: 'Ditt etternavn',
      email: 'E-post',
      emailPlaceholder: 'din@epost.no',
      phone: 'Telefon',
      phonePlaceholder: '+47 000 00 000',
      service: 'Henvendelsen gjelder',
      selectService: 'Velg tjeneste',
      message: 'Din melding',
      messagePlaceholder: 'Fortell oss om prosjektet ditt...',
      submit: 'Send inn',
      sending: 'Sender...',
      success: 'Takk for din henvendelse! Vi tar kontakt med deg snart.',
      error: 'Noe gikk galt. Vennligst prøv igjen eller send e-post til post@mobulamusic.com.',
    };

const finalHeading = heading ?? t.heading;
const finalDescription = description ?? t.description;

const serviceOptions = lang === 'en'
  ? [
      { value: 'film-music', label: 'Film & TV music' },
      { value: 'score-preparation', label: 'Score preparation' },
      { value: 'theatre', label: 'Theatre & stage music' },
      { value: 'recording', label: 'Recording session' },
      { value: 'other', label: 'Other' },
    ]
  : [
      { value: 'innspilling', label: 'Innspilling av musikk' },
      { value: 'podkast', label: 'Podkast' },
      { value: 'voice-over', label: 'Voice-over / Lydbok' },
      { value: 'komponering', label: 'Komposisjon / Produksjon' },
      { value: 'annet', label: 'Annet' },
    ];
---

<section class="py-24 px-6">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-10 fade-in">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-4">{finalHeading}</h2>
      <p class="text-gray-text">{finalDescription}</p>
    </div>

    <form
      id={`form-${formName.toLowerCase().replace(/\s/g, '-')}`}
      class="space-y-6 fade-in"
      data-form-name={formName}
      data-service-type={serviceType || ''}
      data-thanks-url={lang === 'en' ? '/en/thanks' : '/takk'}
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="fornavn" class="block text-sm font-medium text-cream/90 mb-2">{t.firstName} *</label>
          <input
            type="text"
            id="fornavn"
            name="fornavn"
            required
            class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream placeholder-gray-text/50 focus:outline-none focus:border-gold transition-colors"
            placeholder={t.firstNamePlaceholder}
          />
        </div>
        <div>
          <label for="etternavn" class="block text-sm font-medium text-cream/90 mb-2">{t.lastName} *</label>
          <input
            type="text"
            id="etternavn"
            name="etternavn"
            required
            class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream placeholder-gray-text/50 focus:outline-none focus:border-gold transition-colors"
            placeholder={t.lastNamePlaceholder}
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="email" class="block text-sm font-medium text-cream/90 mb-2">{t.email} *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream placeholder-gray-text/50 focus:outline-none focus:border-gold transition-colors"
            placeholder={t.emailPlaceholder}
          />
        </div>
        <div>
          <label for="telefon" class="block text-sm font-medium text-cream/90 mb-2">{t.phone}</label>
          <input
            type="tel"
            id="telefon"
            name="telefon"
            class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream placeholder-gray-text/50 focus:outline-none focus:border-gold transition-colors"
            placeholder={t.phonePlaceholder}
          />
        </div>
      </div>

      {showServiceDropdown && (
        <div>
          <label for="service" class="block text-sm font-medium text-cream/90 mb-2">{t.service} *</label>
          <select
            id="service"
            name="service"
            required
            class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream focus:outline-none focus:border-gold transition-colors"
          >
            <option value="">{t.selectService}</option>
            {serviceOptions.map(opt => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>
      )}

      <div>
        <label for="melding" class="block text-sm font-medium text-cream/90 mb-2">{t.message} *</label>
        <textarea
          id="melding"
          name="melding"
          required
          rows={5}
          class="w-full px-4 py-3 bg-dark-card border border-dark-border rounded text-cream placeholder-gray-text/50 focus:outline-none focus:border-gold transition-colors resize-y"
          placeholder={t.messagePlaceholder}
        ></textarea>
      </div>

      <button
        type="submit"
        data-label-submit={t.submit}
        data-label-sending={t.sending}
        class="w-full sm:w-auto px-8 py-3.5 bg-gold text-dark font-semibold rounded tracking-wide uppercase hover:bg-gold-light transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        {t.submit}
      </button>

      <!-- Status messages -->
      <div id="form-success" class="hidden p-4 bg-green-900/30 border border-green-700/50 rounded text-green-300 text-sm">
        {t.success}
      </div>
      <div id="form-error" class="hidden p-4 bg-red-900/30 border border-red-700/50 rounded text-red-300 text-sm">
        {t.error}
      </div>
    </form>
  </div>
</section>

<script>
  document.querySelectorAll('form[data-form-name]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const btn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
      const successEl = formEl.querySelector('#form-success') as HTMLElement;
      const errorEl = formEl.querySelector('#form-error') as HTMLElement;

      const submitLabel = btn.dataset.labelSubmit || 'Send inn';
      const sendingLabel = btn.dataset.labelSending || 'Sender...';
      btn.disabled = true;
      btn.textContent = sendingLabel;
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      const formName = formEl.dataset.formName || 'Kontaktskjema';
      const serviceType = formEl.dataset.serviceType || '';
      const formData = new FormData(formEl);

      const submissions: Array<{label: string; value: string}> = [];
      submissions.push({ label: 'Fornavn', value: formData.get('fornavn') as string || '' });
      submissions.push({ label: 'Etternavn', value: formData.get('etternavn') as string || '' });
      submissions.push({ label: 'Email', value: formData.get('email') as string || '' });
      submissions.push({ label: 'Telefon', value: formData.get('telefon') as string || '' });

      const service = formData.get('service') as string || serviceType;
      if (service) {
        submissions.push({ label: 'Henvendelsen gjelder', value: service });
      }

      submissions.push({ label: 'Din melding', value: formData.get('melding') as string || '' });

      const payload = {
        data: {
          formName,
          submissions,
        },
      };

      try {
        const webhookUrl = import.meta.env.PUBLIC_CRM_WEBHOOK_URL || '';
        if (!webhookUrl) {
          throw new Error('Webhook URL not configured');
        }

        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          const thanksUrl = formEl.dataset.thanksUrl || '/takk';
          window.location.href = thanksUrl;
          return;
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = submitLabel;
      }
    });
  });
</script>
