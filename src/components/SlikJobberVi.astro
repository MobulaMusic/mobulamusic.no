---
interface Step {
  title: string;
  body: string;
}

interface Props {
  title?: string;
  label?: string;
  intro?: string;
  steps?: Step[];
}

const {
  title = 'Slik jobber vi',
  label = 'Prosessen',
  intro = 'Tre enkle steg fra første e-post til ferdig levering. Ingen overraskelser underveis.',
  steps = [
    {
      title: 'Kontakt & samtale',
      body: 'Du sender oss en kort beskrivelse av prosjektet ditt. Vi svarer innen 1–2 dager med spørsmål, forslag og et fast tilbud du kan forholde deg til.',
    },
    {
      title: 'Studio & innspilling',
      body: 'Vi møtes i studio på Fjellhamar. Tekniker og utstyr er klart når du kommer. Du fokuserer på det musikalske — vi tar oss av alt det tekniske.',
    },
    {
      title: 'Mix, master & levering',
      body: 'Etter innspilling jobber vi videre med mix og mastering. Du får høre underveis, kan komme med innspill, og mottar ferdige filer klare til bruk.',
    },
  ],
} = Astro.props;
---

<section class="py-28 px-6 bg-dark-light">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 fade-in">
      <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">{label}</p>
      <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05] mb-4 max-w-2xl">{title}</h2>
      <p class="text-cream/70 text-base md:text-lg max-w-2xl leading-relaxed">{intro}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10 fade-in">
      {steps.map((step, i) => (
        <div class="relative pt-8 border-t border-cream/10">
          <span class="absolute -top-[1px] left-0 w-16 h-[2px] bg-gold"></span>
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-4">{String(i + 1).padStart(2, '0')} — Steg</p>
          <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-4 leading-tight">{step.title}</h3>
          <p class="text-cream/75 text-base leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
