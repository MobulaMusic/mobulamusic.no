---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Optional extra JSON-LD object (e.g. Service, FAQPage). Added alongside the base LocalBusiness schema. */
  schema?: Record<string, any> | Record<string, any>[];
  /** Page language. 'no' (default) or 'en'. */
  lang?: 'no' | 'en';
  /** Path to the alternate-language version of this page, used for hreflang. */
  altLang?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/studio/store-studio.jpeg',
  schema,
  lang = 'no',
  altLang,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'nb_NO';
const htmlLang = lang === 'en' ? 'en' : 'no';

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://mobula.no/#business",
  "name": "Mobula Music AS",
  "alternateName": "Mobula Music",
  "description": description,
  "url": "https://mobula.no",
  "image": "https://mobula.no/images/logo/mobula-logo.jpg",
  "logo": "https://mobula.no/logo-package/mobula-original.svg",
  "telephone": "+47 920 39 045",
  "email": "post@mobulamusic.com",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Fjellhammerveien 52",
    "addressLocality": "Fjellhamar",
    "postalCode": "1472",
    "addressRegion": "Viken",
    "addressCountry": "NO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.9342,
    "longitude": 10.9578
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Oslo" },
    { "@type": "AdministrativeArea", "name": "Viken" },
    { "@type": "AdministrativeArea", "name": "Innlandet" },
    { "@type": "Country", "name": "Norge" }
  ],
  "sameAs": [
    "https://www.facebook.com/MobulaMusicAS/",
    "https://www.instagram.com/mobula.music",
    "https://www.youtube.com/@mobulamusic_studio"
  ]
};

const extraSchemas = Array.isArray(schema) ? schema : (schema ? [schema] : []);
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-MLCH4GJ5');</script>

  <!-- Meta Pixel -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1227081399231894');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1227081399231894&ev=PageView&noscript=1"
  /></noscript>

  <!-- Google Tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=GT-MQXZXRPX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'GT-MQXZXRPX');
  </script>

  <meta name="robots" content="noindex, nofollow" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- hreflang alternates -->
  {altLang && (
    <>
      <link rel="alternate" hreflang={lang === 'no' ? 'en' : 'no'} href={new URL(altLang, Astro.site).href} />
      <link rel="alternate" hreflang={lang === 'no' ? 'no' : 'en'} href={canonicalURL} />
      <link rel="alternate" hreflang="x-default" href={new URL(lang === 'no' ? Astro.url.pathname : altLang, Astro.site).href} />
    </>
  )}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />

  <!-- Structured Data: Base LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

  {extraSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="min-h-screen flex flex-col">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MLCH4GJ5"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <Header altLang={altLang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />

  <script>
    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
