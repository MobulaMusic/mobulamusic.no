---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** Optional extra JSON-LD object (e.g. Service, FAQPage). Added alongside the base LocalBusiness schema. */
  schema?: Record<string, any> | Record<string, any>[];
  /** Page language. 'no' (default) or 'en'. */
  lang?: 'no' | 'en';
  /** Path to the alternate-language version of this page, used for hreflang. */
  altLang?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/studio/store-studio.jpeg',
  schema,
  lang = 'no',
  altLang,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'nb_NO';
const htmlLang = lang === 'en' ? 'en' : 'no';

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://mobula.no/#business",
  "name": "Mobula Music AS",
  "alternateName": "Mobula Music",
  "description": description,
  "url": "https://mobula.no",
  "image": "https://mobula.no/images/logo/mobula-logo.jpg",
  "logo": "https://mobula.no/logo-package/mobula-original.svg",
  "telephone": "+47 920 39 045",
  "email": "post@mobulamusic.com",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Fjellhammerveien 52",
    "addressLocality": "Fjellhamar",
    "postalCode": "1472",
    "addressRegion": "Viken",
    "addressCountry": "NO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 59.9342,
    "longitude": 10.9578
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Oslo" },
    { "@type": "AdministrativeArea", "name": "Viken" },
    { "@type": "AdministrativeArea", "name": "Innlandet" },
    { "@type": "Country", "name": "Norge" }
  ],
  "sameAs": [
    "https://www.facebook.com/MobulaMusicAS/",
    "https://www.instagram.com/mobula.music",
    "https://www.youtube.com/@mobulamusic_studio"
  ]
};

const extraSchemas = Array.isArray(schema) ? schema : (schema ? [schema] : []);
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- hreflang alternates -->
  {altLang && (
    <>
      <link rel="alternate" hreflang={lang === 'no' ? 'en' : 'no'} href={new URL(altLang, Astro.site).href} />
      <link rel="alternate" hreflang={lang === 'no' ? 'no' : 'en'} href={canonicalURL} />
      <link rel="alternate" hreflang="x-default" href={new URL(lang === 'no' ? Astro.url.pathname : altLang, Astro.site).href} />
    </>
  )}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />

  <!-- Structured Data: Base LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />

  {extraSchemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />

  <script>
    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
