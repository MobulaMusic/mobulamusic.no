---
import Layout from '../../layouts/Layout.astro';
import Mobula from '../../components/Mobula.astro';
---

<Layout
  title="About Mobula Music — Norwegian Recording Studio & Composers"
  description="Two trained film composers and a fully equipped recording studio near Oslo, Norway. Recording, composition and music production under one roof."
  lang="en"
  altLang="/om-oss"
>
  <!-- Hero -->
  <section class="relative pt-40 pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(90vw,1200px)] translate-x-[28%] opacity-[0.15]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-7xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">About us</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-semibold leading-[1.02] mb-8 max-w-4xl">
        A recording studio<br />built for creators
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        Mobula Music is located in Lørenskog, just outside Oslo. We offer recording, composition and production — and always put people and music before gear.
      </p>
    </div>
  </section>

  <!-- Who we are -->
  <section class="py-28 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — Who we are</p>
        <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05] mb-8">A place to make music</h2>
      </div>
      <div class="space-y-6 text-cream/85 text-lg leading-relaxed fade-in">
        <p>
          Mobula Music is a recording studio and production house run by two composers and musicians who decided to bring everything under one roof: recording, editing, mixing, mastering and composition.
        </p>
        <p>
          We enjoy both the creative conversation before a session and the quiet craft afterwards — and we believe the best result comes from having time to do both properly. That's why we work closely with clients across the spectrum: from first-time singer-songwriters to established filmmakers and production companies.
        </p>
        <p>
          We're not the biggest studio in Norway. But we're the place where you're seen, heard and taken seriously — regardless of the size of your project.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 border-y border-cream/10 fade-in">
        <div class="py-8 px-4 md:px-6 border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">50m²</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Main studio</div>
        </div>
        <div class="py-8 px-4 md:px-6 md:border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">4</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Live rooms</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-r border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">15 min</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">From Oslo</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">Free</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Parking</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">02 — The team</p>
        <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05] max-w-2xl">Two composers<br />on the team</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 fade-in">
        <div>
          <div class="relative overflow-hidden aspect-[3/4] mb-6 group bg-dark">
            <img src="/images/team/haakon-esplo.jpg" alt="Haakon Esplo — composer, musician and managing director at Mobula Music" class="w-full h-full object-cover object-top scale-[1.25] origin-top -translate-y-[6%] transition-all duration-700 group-hover:scale-[1.28] [filter:saturate(0.72)_contrast(0.82)_brightness(0.98)] group-hover:[filter:saturate(0.85)_contrast(0.88)_brightness(1.02)]" />
            <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-30 pointer-events-none"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          </div>
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-2">Composer and musician</p>
          <h3 class="text-2xl font-serif font-semibold mb-3">Haakon Esplo</h3>
          <p class="text-cream/75 leading-relaxed text-sm">
            With over 200 published scores, Haakon has written music for symphony orchestra, choir, concert band and chamber ensembles — both original compositions and arrangements. He moves naturally between classical craft and modern production, and is also an established performer and MC.
          </p>
        </div>

        <div>
          <div class="relative overflow-hidden aspect-[3/4] mb-6 group bg-dark">
            <img src="/images/team/olai-forsund.jpeg" alt="Olai Førsund — composer and musician at Mobula Music" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.03] [filter:saturate(0.63)_contrast(0.95)_brightness(0.92)] group-hover:[filter:saturate(0.78)_contrast(1)_brightness(1)]" />
            <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-30 pointer-events-none"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          </div>
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-2">Composer and musician</p>
          <h3 class="text-2xl font-serif font-semibold mb-3">Olai Førsund</h3>
          <p class="text-cream/75 leading-relaxed text-sm">
            Composer and musician with classical training and a solid foot in modern studio production. Olai is equally comfortable with orchestral arrangements for film and TV as with electronic sketches and electroacoustic sound design — a rare breadth that makes him a flexible collaborator on any project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-28 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">03 — Location</p>
        <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05] max-w-2xl">Easy to reach</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start fade-in">
        <div>
          <p class="text-cream/85 text-lg leading-relaxed mb-8">
            We're located at Fjellhammerveien 52 in Lørenskog — a short trip from both Oslo and Lillestrøm. Fjellhamar station is 3 minutes from the studio with trains every 15 minutes, and we have free parking right outside.
          </p>

          <div class="space-y-4 mb-10">
            <div class="flex items-start gap-4 pb-4 border-b border-cream/10">
              <p class="font-mono text-gold text-xs tracking-widest uppercase shrink-0 w-24">Address</p>
              <p class="text-cream/85">Fjellhammerveien 52<br />1472 Fjellhamar, Norway</p>
            </div>
            <div class="flex items-start gap-4 pb-4 border-b border-cream/10">
              <p class="font-mono text-gold text-xs tracking-widest uppercase shrink-0 w-24">Train</p>
              <p class="text-cream/85">Fjellhamar station, 3 min walk<br />15 min from Oslo Central Station</p>
            </div>
            <div class="flex items-start gap-4 pb-4 border-b border-cream/10">
              <p class="font-mono text-gold text-xs tracking-widest uppercase shrink-0 w-24">Car</p>
              <p class="text-cream/85">Free parking right outside</p>
            </div>
            <div class="flex items-start gap-4">
              <p class="font-mono text-gold text-xs tracking-widest uppercase shrink-0 w-24">Phone</p>
              <p class="text-cream/85">
                <a href="tel:+4792039045" class="hover:text-gold transition-colors">+47 920 39 045</a> <span class="text-cream/50">· Haakon</span><br />
                <a href="tel:+4792466150" class="hover:text-gold transition-colors">+47 924 66 150</a> <span class="text-cream/50">· Olai</span>
              </p>
            </div>
          </div>
        </div>

        <div class="relative overflow-hidden h-96 lg:h-[500px] ring-1 ring-inset ring-cream/10">
          <iframe
            src="https://maps.google.com/maps?q=Mobula+Music+AS&t=&z=16&ie=UTF8&iwloc=&output=embed"
            width="100%"
            height="100%"
            style="border:0; filter: grayscale(0.5) contrast(0.95);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mobula Music location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Drop by for a coffee
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        No commitment. We'll gladly give you a tour and hear about your project.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/contact" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Arrange a visit
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          +47 920 39 045
        </a>
      </div>
    </div>
  </section>
</Layout>
