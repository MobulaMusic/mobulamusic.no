---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Thank you! | Mobula Music"
  description="Thanks for your enquiry. We'll be in touch within 1–2 days."
  lang="en"
  altLang="/takk"
>
  <section class="min-h-[70vh] flex items-center px-6 pt-32 pb-20">
    <div class="max-w-2xl mx-auto text-center">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Confirmation</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8">
        Thank you!
      </h1>
      <p class="text-cream/85 text-xl md:text-2xl leading-relaxed mb-4">
        We've received your enquiry and will be in touch within 1–2 days.
      </p>
      <p class="text-cream/70 mb-10">
        If it's urgent, give us a call at <a href="tel:+4792039045" class="text-gold hover:underline">+47 920 39 045</a>.
      </p>
      <a href="/en" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
        Back to home
      </a>
    </div>
  </section>
</Layout>
