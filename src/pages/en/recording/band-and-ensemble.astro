---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import Mobula from '../../../components/Mobula.astro';
import PasserFor from '../../../components/PasserFor.astro';
import ABPlayer from '../../../components/ABPlayer.astro';
import { listReferanser } from '../../../lib/content';
const referanser = (await listReferanser()).filter(r => r.kategori === 'band-og-ensemble');
---

<Layout
  title="Band & Ensemble Recording — 50 m² Main Studio | Mobula Music"
  description="Live recording of bands, concert bands, choirs and ensembles in a 50 m² main studio with multiple connected live rooms. Record together with great separation and experienced engineers."
  lang="en"
  altLang="/innspilling/band-og-ensemble"
>
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(80vw,1000px)] translate-x-[30%] opacity-[0.12]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-5xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">
        <a href="/en/recording" class="hover:text-gold-light">Recording</a> / Band & Ensemble
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8 max-w-4xl">
        When you play<br />together
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        Bands, concert bands, choirs and larger ensembles. A 50 m² main studio with multiple connected live rooms — so you can play together with both energy and separation.
      </p>
    </div>
  </section>

  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — What we have</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05] max-w-2xl">Rooms that work together</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 fade-in">
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">50 m² main studio</h3>
          <p class="text-cream/75 leading-relaxed">
            Large enough for a full band setup with drums, bass, guitar and keys playing at once. Natural room sound that works for both tight modern productions and more open acoustic recordings.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Connected vocal and iso rooms</h3>
          <p class="text-cream/75 leading-relaxed">
            Multiple rooms linked to the same control room. Record live without bleed into every mic — or move the vocalist to a separate room when you're chasing keepers.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Concert band and choir</h3>
          <p class="text-cream/75 leading-relaxed">
            The main studio handles smaller concert band and choir ensembles. We adapt the microphone setup to the ensemble and the music.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Engineer and producer</h3>
          <p class="text-cream/75 leading-relaxed">
            Experienced engineers who know how to get the best out of group dynamics. A producer is available if you want extra help with arrangements and decisions along the way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PasserFor
    title="Built for bands"
    label="Welcome"
    intro="Bands that play together sound better together. We set everything up so you can do exactly that."
    items={[
      'You\'re a band recording an EP or an album.',
      'You\'re a concert band or choir that wants a professional recording.',
      'You\'re a cover or tribute band that wants to capture your live sound.',
      'You\'re a school band or hobby ensemble trying out a real studio.',
      'You want to play together — not track one instrument at a time.',
    ]}
  />

  {referanser.length > 0 && (
    <section class="py-28 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Before / after</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Band sessions — raw vs. mixed</h2>
        </div>
        <ABPlayer referanser={referanser} />
      </div>
    </section>
  )}

  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">Book a session</h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">Tell us about the lineup, the repertoire and the time frame, and we'll give you a fixed&nbsp;quote.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/contact" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Get in touch
        </a>
        <a href="/en/recording" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          See other services
        </a>
      </div>
    </div>
  </section>
</Layout>
