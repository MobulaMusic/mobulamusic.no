---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import Mobula from '../../../components/Mobula.astro';
import PasserFor from '../../../components/PasserFor.astro';
import ABPlayer from '../../../components/ABPlayer.astro';
import { listReferanser } from '../../../lib/content';
const referanser = (await listReferanser()).filter(r => r.kategori === 'vokal');
---

<Layout
  title="Vocal Recording near Oslo — Lead, Choir & Classical | Mobula Music"
  description="Professional vocal recording in acoustically treated rooms near Oslo. Lead vocals, backing vocals, classical soloists or choirs — microphones and rooms tailored to your voice."
  lang="en"
  altLang="/innspilling/vokal"
>
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(80vw,1000px)] translate-x-[30%] opacity-[0.12]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-5xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">
        <a href="/en/recording" class="hover:text-gold-light">Recording</a> / Vocal Recording
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8 max-w-4xl">
        Make your voice shine
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        Professional vocal recording for artists, backing singers and classical vocalists. Acoustically treated vocal rooms in Lørenskog — a short trip from central Oslo.
      </p>
    </div>
  </section>

  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — What we offer</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05] max-w-2xl">Vocal rooms tailored<br />to your voice</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 fade-in">
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Lead vocals</h3>
          <p class="text-cream/75 leading-relaxed">
            Several vocal rooms for recording lead vocals — from dry and close to more open and airy. We choose microphones, room and signal chain based on the character of your voice and the genre you work in.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Backing vocals and harmonies</h3>
          <p class="text-cream/75 leading-relaxed">
            Layer upon layer of backing vocals, harmonies and choir parts. Several of our vocal rooms are connected to the same control room, so building up stacks is fast.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Classical solo and choir</h3>
          <p class="text-cream/75 leading-relaxed">
            Our main studio has a natural reverberation that suits classical vocalists, ensembles and smaller choirs. We can record with room sound or dry for post-production — suited for lieder, opera and sacred repertoire.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Producer in the room</h3>
          <p class="text-cream/75 leading-relaxed">
            Need someone to push, suggest phrasings or pick takes? A producer is available on request.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PasserFor
    title="Built for you, whatever the session"
    label="Welcome"
    items={[
      'You\'re an artist who needs professional lead vocals on a release.',
      'You\'re recording backing vocals or harmony stacks.',
      'You\'re a classical vocalist and want to record repertoire or audition takes.',
      'You lead a choir that needs to be recorded.',
      'You want a calm, unhurried environment for your vocal takes.',
    ]}
  />

  {referanser.length > 0 && (
    <section class="py-28 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Before / after</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Vocal examples — raw vs. mixed</h2>
        </div>
        <ABPlayer referanser={referanser} />
      </div>
    </section>
  )}

  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">Book a vocal session</h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">Tell us about your project — what genre, how many songs — and we'll find the time and vocal room that fits.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/contact" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Get in touch
        </a>
        <a href="/en/recording" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          See other services
        </a>
      </div>
    </div>
  </section>
</Layout>
