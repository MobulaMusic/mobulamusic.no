---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Mobula from '../../components/Mobula.astro';
import PasserFor from '../../components/PasserFor.astro';
import SlikJobberVi from '../../components/SlikJobberVi.astro';
import Faq from '../../components/Faq.astro';
import KundeSitater from '../../components/KundeSitater.astro';
import { listKunder } from '../../lib/content';
const kunder = (await listKunder()).filter(k => k.tags?.some(t => ['podkast', 'podcast'].includes(t))).slice(0, 2);

const services = [
  {
    num: '01',
    title: 'Recording',
    intro: 'Audio and video in the same studio. Professional microphones, multi-camera setup and an engineer — you focus on the conversation.',
    image: '/images/podcast/podkast-studio.jpeg',
    alt: 'Podcast recording with professional microphones and video setup',
  },
  {
    num: '02',
    title: 'Editing',
    intro: 'We take the recording and finish it. Cleaning, cutting hum, pauses and false starts, and delivery in your preferred format.',
    image: '/images/podcast/klipping.jpeg',
    alt: 'Podcast editing in DAW with multiple audio tracks',
  },
  {
    num: '03',
    title: 'Sound Design',
    intro: 'Intro, outro, transitions and soundscapes that give your podcast its own identity.',
    image: '/images/podcast/lyddesign.jpeg',
    alt: 'Sound design and audio landscape for podcast production',
  },
  {
    num: '04',
    title: 'Original Music',
    intro: 'Custom theme music, jingles and background tracks composed specifically for your show. You own the music.',
    image: '/images/podcast/originalmusikk.png',
    alt: 'Original music composition for podcast',
  },
  {
    num: '05',
    title: 'Coaching',
    intro: 'Want to make a podcast yourself? We take you through concept, technique, interviewing, editing and publishing.',
    image: '/images/podcast/opplaring.jpeg',
    alt: 'Podcast coaching and training session',
  },
];
---

<Layout
  title="Podcast Studio in Lørenskog — from recording to finished episode | Mobula Music"
  description="Professional podcast studio in Lørenskog, 15 minutes from Oslo. Audio and video recording, editing, sound design, original music and coaching. Packages from NOK 4 500 incl. VAT."
  lang="en"
  altLang="/podkast"
>
  <!-- Hero -->
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(90vw,1200px)] translate-x-[28%] opacity-[0.15]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-7xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Podcast</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-semibold leading-[1.02] mb-8 max-w-4xl">
        Podcast studio<br />in Lørenskog
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed mb-4">
        Recording, editing, sound design, music and coaching — everything under one roof. From recording to finished episode. 15 min from Oslo central.
      </p>
      <p class="text-gold text-lg md:text-xl font-semibold mb-10">Packages from NOK 4 500 incl. VAT</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/en/contact?tjeneste=podkast" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Get a quote
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          Call +47 920 39 045
        </a>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 px-6 border-b border-dark-border/40">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fade-in">
        {[
          ['Audio and video in the same studio', 'Multi-camera setup with professional lighting.'],
          ['Fixed quote before we start', 'You know what it costs before we begin.'],
          ['Experienced engineers', '10+ years of audio production experience.'],
          ['15 min from Oslo central', '3 min walk from Fjellhamar station.'],
          ['Free parking', 'Easy to arrive with guests and gear.'],
          ['Ready for publishing', 'Delivered in every standard podcast format.'],
        ].map(([title, desc]) => (
          <div class="flex gap-3 items-start">
            <span class="text-gold text-lg leading-none mt-0.5">✓</span>
            <div>
              <p class="font-semibold text-sm mb-1">{title}</p>
              <p class="text-cream/60 text-sm">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Passer for -->
  <PasserFor
    title="Built for you, whatever the project"
    label="Welcome"
    intro="We've recorded everything from the very first episode of a hobby series to finished productions for major podcast networks."
    items={[
      'You have a great idea for a podcast and want to do it right from the start.',
      'You already have a series and need a reliable studio.',
      'You\'re a company that wants to launch a podcast as part of your brand.',
      'You\'re an author, speaker or expert who wants to share knowledge.',
      'You want to learn how to make podcasts yourself — from start to finish.',
    ]}
  />

  <!-- Services grid -->
  <section class="py-28 md:py-36 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">What we offer</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Everything you need,<br />in one place</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Pick one service or the whole package — we adapt to your project and budget.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((s) => (
          <div class="group fade-in">
            <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
              <img src={s.image} alt={s.alt} class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)] group-hover:[filter:saturate(0.85)_contrast(1)_brightness(1)]" />
              <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-30 pointer-events-none"></div>
              <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
              <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
              <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
              <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">{s.num}</span>
            </div>
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2">{s.title}</h3>
              <p class="text-cream/70 text-sm leading-relaxed">{s.intro}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <SlikJobberVi
    label="Process"
    title="How to get started"
    intro="You don't need everything figured out from the start. We help you through the whole process."
    steps={[
      {
        title: 'Idea & conversation',
        body: 'We talk through your concept — audience, theme, format and frequency. You get suggestions and a fixed quote.',
      },
      {
        title: 'Studio & recording',
        body: 'You come to the studio, the engineer sets everything up, and you can start straight away. Top-quality audio and video, every time.',
      },
      {
        title: 'Editing & delivery',
        body: 'We edit, mix and add music and sound design. You receive finished episodes ready to upload to Spotify or other podcast platforms.',
      },
    ]}
  />

  <!-- Studio photos -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">The studio</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">The room you record in</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 fade-in">
        <img src="/images/podcast/recording-podcast.png" alt="Podcast recording at Mobula Music" loading="lazy" class="w-full aspect-[4/3] object-cover md:col-span-2 md:row-span-2 md:aspect-auto md:h-full" />
        <img src="/images/podcast/podkast-studio.jpeg" alt="Podcast studio with professional lighting" loading="lazy" class="w-full aspect-[4/3] object-cover" />
        <img src="/images/studio/producing-podcast.png" alt="Podcast production and editing" loading="lazy" class="w-full aspect-[4/3] object-cover" />
      </div>
    </div>
  </section>

  {kunder.length > 0 && (
    <section class="py-24 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-10 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Client stories</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">What podcast clients say</h2>
        </div>
        <KundeSitater kunder={kunder} />
      </div>
    </section>
  )}

  <!-- FAQ -->
  <Faq
    label="FAQ"
    title="Frequently asked questions"
    items={[
      {
        q: 'I\'ve never recorded a podcast before — can I still start?',
        a: 'Definitely. Many of our clients are first-time podcasters. We take time to explain everything, and you don\'t need any technical knowledge or experience in front of a microphone.',
      },
      {
        q: 'Do you speak English?',
        a: 'Yes, both engineers speak fluent English. We work regularly with English-speaking podcasters and producers in Norway.',
      },
      {
        q: 'Can I record video at the same time?',
        a: 'Yes. We have a multi-camera setup with professional lighting, so you can easily make a video podcast for YouTube alongside the audio.',
      },
      {
        q: 'Do I own my podcast?',
        a: 'Yes, always. You own the recordings and rights to everything we create for you — including music and sound design. We can also help you publish if you don\'t want to do it yourself.',
      },
      {
        q: 'Can you help me start from scratch?',
        a: 'Yes. We offer <strong class="text-cream">coaching</strong> that takes you through the whole process — from idea and concept development to technical setup, interview techniques, editing and publishing.',
      },
    ]}
  />

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Ready to record?
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        Tell us about your podcast project — we'll reply within 1–2 days with questions, ideas and a fixed&nbsp;quote.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/en/contact" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Get in touch
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          +47 920 39 045
        </a>
      </div>
    </div>
  </section>
</Layout>
