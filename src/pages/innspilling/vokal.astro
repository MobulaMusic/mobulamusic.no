---
export const prerender = false;
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Mobula from '../../components/Mobula.astro';
import PasserFor from '../../components/PasserFor.astro';
import ABPlayer from '../../components/ABPlayer.astro';
import Faq from '../../components/Faq.astro';
import KundeSitater from '../../components/KundeSitater.astro';
import { listReferanser, listKunder } from '../../lib/content';
import { operaMainStudio, vokalrom1, vokalrom2 } from '../../assets/images';
const referanser = (await listReferanser()).filter(r => r.kategori === 'vokal');
const kunder = (await listKunder()).filter(k => k.tags?.some(t => ['vokal', 'innspilling'].includes(t))).slice(0, 2);
---

<Layout
  title="Vokalinnspilling i Lørenskog — 15 min fra Oslo S | Mobula Music"
  description="Profesjonell vokalinnspilling i akustisk behandlede rom. Lead-vokal, kor eller klassisk. 15 min fra Oslo S, gratis parkering."
  altLang="/en/recording/vocal"
>
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(80vw,1000px)] translate-x-[30%] opacity-[0.12]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-5xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">
        <a href="/innspilling" class="hover:text-gold-light">Innspilling</a> / Vokalinnspilling
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8 max-w-4xl">
        Vokalinnspilling<br />i Lørenskog
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed mb-4">
        Akustisk behandlede vokalrom, erfarne teknikere og fast pris før vi starter. Lead-vokal, kor eller klassisk — 15 min fra Oslo S.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/kontakt?tjeneste=vokal" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Få tilbud
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          Ring 920 39 045
        </a>
      </div>
    </div>
  </section>

  <!-- Fordeler -->
  <section class="py-20 px-6 border-b border-dark-border/40">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 fade-in">
        {[
          ['Akustisk behandlede vokalrom', 'Flere rom for ulike stemmer og sjangre.'],
          ['Fast pris før oppstart', 'Du vet hva det koster før vi begynner.'],
          ['Erfarne teknikere', '10+ års erfaring med vokalopptak.'],
          ['15 min fra Oslo S', '3 min gange fra Fjellhamar stasjon.'],
          ['Gratis parkering', 'Lett å komme med utstyr eller band.'],
          ['Topp mikrofoner', 'Neumann, Sennheiser, Shure — vi velger etter stemmen.'],
        ].map(([title, desc]) => (
          <div class="flex gap-3 items-start">
            <span class="text-gold text-lg leading-none mt-0.5">✓</span>
            <div>
              <p class="font-semibold text-sm mb-1">{title}</p>
              <p class="text-cream/60 text-sm">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — Hva vi tilbyr</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05] max-w-2xl">Vokalrom tilpasset<br />stemmen din</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 fade-in">
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Lead-vokal</h3>
          <p class="text-cream/75 leading-relaxed">
            Flere vokalrom for innspilling av lead-vokal — fra det tørre og nære til det mer luftige. Vi velger mikrofon, rom og signalkjede etter stemmens karakter og sjangeren du jobber i.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Korstemmer og backing</h3>
          <p class="text-cream/75 leading-relaxed">
            Lag på lag med backing-vokal, stemmeføring og harmonier. Flere av vokalrommene våre er koblet til samme kontrollrom, så det går raskt å bygge opp.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Klassisk solo og kor</h3>
          <p class="text-cream/75 leading-relaxed">
            Hovedstudioet vårt har naturlig klang som passer klassiske vokalister, ensembler og mindre kor. Vi kan jobbe med romklang eller tørt opptak for etterbehandling — tilpasset både lied-repertoar, opera og sakral musikk.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Produsent i rommet</h3>
          <p class="text-cream/75 leading-relaxed">
            Trenger du noen til å pushe, foreslå fraseringer eller velge takes? Produsent er tilgjengelig på forespørsel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PasserFor
    items={[
      'Du er artist og trenger profesjonell lead-vokal på en utgivelse.',
      'Du skal spille inn backing-vokal eller korstemmer.',
      'Du er klassisk vokalist og vil spille inn repertoar eller søknadsopptak.',
      'Du leder et kor som trenger innspilling.',
      'Du vil ha en trygg ramme rundt vokalopptakene — ikke stress.',
    ]}
  />

  <!-- Studiobilder -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Studioet</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Rommene vi spiller inn i</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 fade-in">
        <Image src={operaMainStudio} alt="Klassisk vokalist synger i hovedstudio hos Mobula Music" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" loading="lazy" class="w-full aspect-[4/5] object-cover" />
        <Image src={vokalrom1} alt="Vokalrom med akustisk behandling hos Mobula Music" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" loading="lazy" class="w-full aspect-[4/5] object-cover" />
        <Image src={vokalrom2} alt="Vokalrom med Neumann-mikrofon hos Mobula Music" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" loading="lazy" class="w-full aspect-[4/5] object-cover" />
      </div>
    </div>
  </section>

  {referanser.length > 0 && (
    <section class="py-28 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Før / etter</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Vokaleksempler — rå vs. mikset</h2>
        </div>
        <ABPlayer referanser={referanser} />
      </div>
    </section>
  )}

  {kunder.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="mb-10 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Kundehistorier</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Det vokalistene sier</h2>
        </div>
        <KundeSitater kunder={kunder} />
      </div>
    </section>
  )}

  <Faq
    title="Vanlige spørsmål"
    items={[
      {
        q: 'Hva koster det?',
        a: 'Se <a href="/priser" class="text-gold hover:underline">prisene våre</a> for full oversikt, eller send oss en henvendelse så gir vi et fast tilbud før vi starter.',
      },
      {
        q: 'Hvordan booker jeg?',
        a: 'Send oss en melding via <a href="/kontakt" class="text-gold hover:underline">skjemaet</a>, ring 920 39 045, eller send e-post til post@mobulamusic.com. Vi svarer innen 1–2 dager med spørsmål og et fast tilbud.',
      },
      {
        q: 'Kan jeg komme innom først for å se studioet?',
        a: 'Ja, helt fint. Mange ønsker å se rommet og møte teknikeren før de booker. Send oss en melding så avtaler vi et tidspunkt som passer.',
      },
      {
        q: 'Hvor lang tid tar en vokalinnspilling?',
        a: 'En enkel lead-vokal på én låt går unna på 2–3 timer inkludert oppsett. Flere låter eller lagde harmonier tar lengre tid. Vi gir deg et ærlig estimat før du booker slik at du ikke booker for lite eller for mye.',
      },
      {
        q: 'Hvor mange opptak kan jeg gjøre?',
        a: 'Så mange du trenger innenfor tiden du har booket. Vi anbefaler flere takes av hver frase slik at vi kan komponere den beste versjonen i miksen.',
      },
      {
        q: 'Hva skjer etter at jeg sender skjemaet?',
        a: 'Du får svar innen 1–2 dager. Vi stiller noen oppfølgingsspørsmål om prosjektet, foreslår et opplegg, og sender et fast tilbud. Når du godtar, finner vi en dato som passer.',
      },
    ]}
  />

  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">Book vokalinnspilling</h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">Fortell oss om prosjektet ditt — hvilken sjanger, hvor mange låter — så finner vi tid og vokalrom som passer.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Ta kontakt
        </a>
        <a href="/innspilling" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          Se andre tjenester
        </a>
      </div>
    </div>
  </section>
</Layout>
