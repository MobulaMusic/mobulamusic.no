---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Mobula from '../../components/Mobula.astro';
import PasserFor from '../../components/PasserFor.astro';
import ABPlayer from '../../components/ABPlayer.astro';
import { listReferanser } from '../../lib/content';
const referanser = (await listReferanser()).filter(r => r.kategori === 'singer-songwriter');
---

<Layout
  title="Innspilling for Singer-Songwriter — Demo, Singel & EP | Mobula Music"
  description="Lydstudio for singer-songwriter på Østlandet. Spill inn låter alene eller med band, fra første demo til ferdig singel klar for Spotify. Vi tilpasser produksjonen til låta di."
  altLang="/en/recording/singer-songwriter"
>
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(80vw,1000px)] translate-x-[30%] opacity-[0.12]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-5xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">
        <a href="/innspilling" class="hover:text-gold-light">Innspilling</a> / Singer-songwriter
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8 max-w-4xl">
        Få låtene dine ut i verden
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        For deg som skriver egne låter og vil ha dem ordentlig innspilt. Alene med gitaren, eller med full bandproduksjon — vi finner formatet som passer låta.
      </p>
    </div>
  </section>

  <section class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — Hva du får</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05] max-w-2xl">Alt du trenger,<br />ingenting mer</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 fade-in">
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Intim produksjon</h3>
          <p class="text-cream/75 leading-relaxed">
            Gitar og vokal, piano og vokal, eller bare stemme. Vi finner mikrofoner og rom som fanger det nære og ekte i det du gjør.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Full bandproduksjon</h3>
          <p class="text-cream/75 leading-relaxed">
            Trenger låta di trommer, bass og lag på lag? Vi bygger arrangementet sammen med deg og spiller inn alt — enten du har band selv eller trenger session-musikere.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Arrangement og produsering</h3>
          <p class="text-cream/75 leading-relaxed">
            Hvis du er usikker på hvor låta skal gå videre, kan vi også hjelpe med arrangement og produsering — ikke bare teknisk innspilling. Se <a href="/musikk/produsering" class="text-gold hover:underline">Produsering</a> for mer.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-serif font-semibold mb-3 text-gold">Klar for utgivelse</h3>
          <p class="text-cream/75 leading-relaxed">
            Vi leverer ferdig masteret track klart for Spotify, Apple Music og alt annet. Du eier låta og opptakene.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PasserFor
    intro="Vi har spilt inn mange første singler, og minst like mange låt nummer 47 i karrieren. Begge er like viktige."
    items={[
      'Du har en låt du har sittet med lenge og vil endelig få den ut.',
      'Du har en demo og vil gjøre den om til en ordentlig utgivelse.',
      'Du har flere låter du vil samle til en EP.',
      'Du vil ha hjelp til å finne lyden din — ikke bare spille inn.',
      'Du har aldri gjort dette før og vil ha en trygg start.',
    ]}
  />

  {referanser.length > 0 && (
    <section class="py-28 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Før / etter</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Singer-songwriter — rå vs. mikset</h2>
        </div>
        <ABPlayer referanser={referanser} />
      </div>
    </section>
  )}

  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Send oss låta di
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        Voice-memo, demo, tekst eller bare en beskrivelse. Vi tar det videre&nbsp;derfra.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Ta kontakt
        </a>
        <a href="/innspilling" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          Se andre tjenester
        </a>
      </div>
    </div>
  </section>
</Layout>
