---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { listPosts } from '../../lib/content';

const posts = await listPosts();
---

<Layout
  title="Blogg | Nyheter fra Mobula Music AS"
  description="Les siste nytt fra Mobula Music. Tips om innspilling, podkast, komposisjon og studioarbeid."
>
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-gold tracking-[0.2em] uppercase text-sm mb-4">Blogg</p>
        <h1 class="text-4xl md:text-5xl font-serif font-bold">Nyheter og tips</h1>
      </div>

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/nyheter/${post.slug}`} class="block group">
            <article class="bg-dark-card border border-dark-border rounded-lg overflow-hidden hover:border-gold/30 transition-colors">
              <div class="flex flex-col md:flex-row">
                {post.image && (
                  <div class="md:w-72 shrink-0">
                    <img src={post.image} alt={post.title} class="w-full h-48 md:h-full object-cover" />
                  </div>
                )}
                <div class="p-6 flex flex-col justify-center">
                  <time class="text-gold text-xs uppercase tracking-wide mb-2">
                    {new Date(post.date).toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <h2 class="text-xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">{post.title}</h2>
                  <p class="text-cream/75 text-sm line-clamp-2">{post.description}</p>
                  {post.tags && (
                    <div class="flex gap-2 mt-3">
                      {post.tags.map((tag: string) => (
                        <span class="text-xs px-2 py-1 bg-dark-border rounded text-cream/50">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
