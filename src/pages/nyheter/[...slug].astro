---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getPost, renderMarkdown } from '../../lib/content';

const { slug } = Astro.params;
const post = await getPost(String(slug));
if (!post) return Astro.redirect('/nyheter');
const html = renderMarkdown(post.body);
---

<Layout
  title={`${post.title} | Mobula Music AS`}
  description={post.description}
  ogImage={post.image}
>
  <article class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/nyheter" class="text-gold text-sm hover:underline mb-8 inline-block">&larr; Tilbake til blogg</a>

      {post.image && (
        <img src={post.image} alt={post.title} class="w-full h-64 md:h-96 object-cover rounded-lg mb-8" />
      )}

      <time class="text-gold text-sm uppercase tracking-wide">
        {new Date(post.date).toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>

      <h1 class="text-3xl md:text-5xl font-serif font-bold mt-3 mb-8">{post.title}</h1>

      <div class="prose prose-invert prose-lg max-w-none
        [&_h2]:font-serif [&_h2]:text-cream [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:font-serif [&_h3]:text-cream [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-cream/85 [&_p]:leading-relaxed [&_p]:mb-4
        [&_li]:text-cream/85
        [&_a]:text-gold [&_a:hover]:underline
        [&_strong]:text-cream
      " set:html={html}></div>

      {post.tags && (
        <div class="flex gap-2 mt-10 pt-8 border-t border-dark-border">
          {post.tags.map((tag: string) => (
            <span class="text-xs px-3 py-1.5 bg-dark-card border border-dark-border rounded text-cream/50">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>
</Layout>
