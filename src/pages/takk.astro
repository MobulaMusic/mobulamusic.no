---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Takk! | Mobula Music"
  description="Takk for din henvendelse. Vi svarer innen 1–2 dager."
  altLang="/en/thanks"
>
  <section class="min-h-[70vh] flex items-center px-6 pt-32 pb-20">
    <div class="max-w-2xl mx-auto text-center">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Bekreftelse</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] mb-8">
        Takk!
      </h1>
      <p class="text-cream/85 text-xl md:text-2xl leading-relaxed mb-4">
        Vi har mottatt forespørselen din og svarer innen 1–2 dager.
      </p>
      <p class="text-cream/70 mb-10">
        Hvis det haster, ring oss på <a href="tel:+4792039045" class="text-gold hover:underline">+47 920 39 045</a>.
      </p>
      <a href="/" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
        Tilbake til forsiden
      </a>
    </div>
  </section>
</Layout>
