---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Komposisjon | Musikk til film, TV og reklame | Mobula Music AS"
  description="Vi skaper skreddersydd musikk til film, TV, reklame og podkast. Fra idé til ferdig produksjon med erfarne komponister og musikere."
  ogImage="/images/strings/nordic-film-strings.jpg"
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 px-6">
    <div class="absolute inset-0 z-0">
      <img src="/images/strings/orkester.jpeg" alt="Orkesterinnspilling" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/70 to-dark"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-gold tracking-[0.2em] uppercase text-sm mb-4">Komposisjon & Produksjon</p>
      <h1 class="text-4xl md:text-6xl font-serif font-bold mb-6">Vi skaper musikken</h1>
      <p class="text-cream/85 text-lg max-w-2xl mx-auto">
        Skreddersydd musikk til film, TV, reklame og podkast. Vi kombinerer kunstnerisk kvalitet med faglig tyngde.
      </p>
    </div>
  </section>

  <!-- What we do -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20 fade-in">
        <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-4">Fra idé til ferdig produksjon</h2>
        <p class="text-cream/85 max-w-2xl mx-auto">
          Vi komponerer, arrangerer og produserer musikk for alle typer visuelle medier. Enten det er en spillefilm, en reklamekampanje eller en podkast-vignett — vi leverer musikk som forsterker budskapet ditt.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 fade-in">
        <div class="card-glass rounded-lg p-6 text-center card-hover">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m0 0h4a1 1 0 011 1v1a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1h4m0 0V2" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l-4 4m0-4l4 4" /></svg>
          </div>
          <h3 class="text-cream font-semibold mb-2">Film & TV</h3>
          <p class="text-cream/75 text-sm">Filmmusikk, dramaserier og dokumentar</p>
        </div>

        <div class="card-glass rounded-lg p-6 text-center card-hover">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg>
          </div>
          <h3 class="text-cream font-semibold mb-2">Reklame</h3>
          <p class="text-cream/75 text-sm">Reklamefilmer, jingles og kampanjer</p>
        </div>

        <div class="card-glass rounded-lg p-6 text-center card-hover">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
          </div>
          <h3 class="text-cream font-semibold mb-2">Podkast</h3>
          <p class="text-cream/75 text-sm">Vignetter, overganger og lydlandskap</p>
        </div>

        <div class="card-glass rounded-lg p-6 text-center card-hover">
          <div class="w-14 h-14 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
          </div>
          <h3 class="text-cream font-semibold mb-2">Arrangement</h3>
          <p class="text-cream/75 text-sm">Orkester, strykere, band og ensemble</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 px-6 bg-dark-light">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold text-center mb-20 fade-in">Vår prosess</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 fade-in">
        <div class="text-center">
          <div class="w-16 h-16 bg-gold/10 border border-gold/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-gold font-serif text-xl font-bold">1</span>
          </div>
          <h3 class="text-cream font-semibold mb-2">Brief</h3>
          <p class="text-cream/75 text-sm">Vi lytter til dine behov og forstår prosjektet ditt</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-gold/10 border border-gold/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-gold font-serif text-xl font-bold">2</span>
          </div>
          <h3 class="text-cream font-semibold mb-2">Skisse</h3>
          <p class="text-cream/75 text-sm">Vi lager musikalske skisser og forslag</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-gold/10 border border-gold/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-gold font-serif text-xl font-bold">3</span>
          </div>
          <h3 class="text-cream font-semibold mb-2">Produksjon</h3>
          <p class="text-cream/75 text-sm">Innspilling, arrangering og miksing</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-gold/10 border border-gold/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-gold font-serif text-xl font-bold">4</span>
          </div>
          <h3 class="text-cream font-semibold mb-2">Levering</h3>
          <p class="text-cream/75 text-sm">Ferdig mastering og levering i ønsket format</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold text-center mb-20 fade-in">Våre komponister</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <!-- Olai -->
        <div class="fade-in">
          <div class="aspect-[3/4] overflow-hidden rounded-lg mb-6">
            <img src="/images/team/olai-forsund.jpeg" alt="Olai Førsund" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-serif font-semibold mb-2">Olai Førsund</h3>
          <p class="text-gold text-sm mb-3">Komponist og musiker</p>
          <p class="text-cream/85 text-sm leading-relaxed">
            Komponist og musiker basert i Oslo. Olai har bred erfaring med komposisjon og arrangement for orkester, film og TV. Han kombinerer klassisk skolering med moderne produksjonsteknikker.
          </p>
        </div>

        <!-- Haakon -->
        <div class="fade-in">
          <div class="aspect-[3/4] overflow-hidden rounded-lg mb-6">
            <img src="/images/team/haakon-esplo.jpg" alt="Haakon Esplo" class="w-full h-full object-cover" />
          </div>
          <h3 class="text-xl font-serif font-semibold mb-2">Haakon Esplo</h3>
          <p class="text-gold text-sm mb-3">Komponist og musiker</p>
          <p class="text-cream/85 text-sm leading-relaxed">
            Komponist og musiker med solid bakgrunn innen musikkteori og produksjon. Haakon har lang erfaring med komposisjon for ulike sjangre og ensemble, og er daglig leder i Mobula Music.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactForm
    formName="Komposisjon"
    serviceType="komponering"
    heading="Fortell om prosjektet ditt"
    description="Beskriv prosjektet, tidsramme og budsjett — så tar vi kontakt for en uforpliktende prat."
  />
</Layout>
