---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Innspilling | Vokal, Lydbok, Band & Ensemble | Mobula Music AS"
  description="Profesjonell innspilling av vokal, lydbok, voice-over og ensemble i akustisk optimaliserte studioer. Erfarne teknikere. Kort vei fra Oslo og Lillestrøm."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 px-6">
    <div class="absolute inset-0 z-0">
      <img src="/images/studio/store-studio.jpeg" alt="Innspillingsstudio" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/70 to-dark"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-gold tracking-[0.2em] uppercase text-sm mb-4">Innspilling</p>
      <h1 class="text-4xl md:text-6xl font-serif font-bold mb-6">Profesjonell innspilling i studio</h1>
      <p class="text-cream/85 text-lg max-w-2xl mx-auto">
        Singel, album, demo, lydbok eller voice-over — vi hjelper deg å få det til å låte akkurat slik du vil.
      </p>
    </div>
  </section>

  <!-- Navigation tabs -->
  <nav class="sticky top-16 z-30 bg-dark-light/95 backdrop-blur-md border-b border-dark-border">
    <div class="max-w-4xl mx-auto px-6 flex gap-8 overflow-x-auto">
      <a href="#vokal" class="py-4 text-sm font-medium tracking-wide uppercase text-cream/75 hover:text-gold border-b-2 border-transparent hover:border-gold transition-colors whitespace-nowrap">Vokal</a>
      <a href="#lydbok" class="py-4 text-sm font-medium tracking-wide uppercase text-cream/75 hover:text-gold border-b-2 border-transparent hover:border-gold transition-colors whitespace-nowrap">Lydbok & Voice-over</a>
      <a href="#ensemble" class="py-4 text-sm font-medium tracking-wide uppercase text-cream/75 hover:text-gold border-b-2 border-transparent hover:border-gold transition-colors whitespace-nowrap">Band & Ensemble</a>
    </div>
  </nav>

  <!-- Vokal -->
  <section id="vokal" class="py-24 px-6 scroll-mt-32">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="text-gold tracking-[0.2em] uppercase text-sm mb-3">Vokalinnspilling</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Få stemmen din til å skinne</h2>
          <p class="text-cream/85 leading-relaxed mb-6">
            Singel, album eller demo — hos oss får du teknikere som fokuserer på detaljene, et studio bygget for vokal, og tid til å gjøre det skikkelig. Vi sørger for at oppsett, mikrofoner og romakustikk er optimalt tilpasset din stemme.
          </p>
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-gold mt-2 shrink-0"></div>
              <div>
                <span class="text-cream font-medium">Innspilling med tekniker</span>
                <span class="text-cream/75"> — Oppsett, mikrofoner, romakustikk inkludert. Fra 2 500,-</span>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-gold mt-2 shrink-0"></div>
              <div>
                <span class="text-cream font-medium">Gjør-det-selv</span>
                <span class="text-cream/75"> — Tilgang til studio med utstyr. 985,- per time</span>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-gold mt-2 shrink-0"></div>
              <div>
                <span class="text-cream font-medium">Kun studio</span>
                <span class="text-cream/75"> — Studiorom uten utstyr. 675,- per time</span>
              </div>
            </div>
          </div>
        </div>
        <div class="fade-in">
          <img src="/images/studio/vokalrom-1.jpeg" alt="Vokalinnspilling" class="rounded-lg w-full object-cover aspect-[4/3]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Lydbok & Voice-over -->
  <section id="lydbok" class="py-24 px-6 bg-dark-light scroll-mt-32">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 fade-in">
          <img src="/images/voice-over/voice-studio.jpg" alt="Lydbok og voice-over" class="rounded-lg w-full object-cover aspect-[4/3]" />
        </div>
        <div class="order-1 lg:order-2 fade-in">
          <p class="text-gold tracking-[0.2em] uppercase text-sm mb-3">Lydbok & Voice-over</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Profesjonelle taleopptak</h2>
          <p class="text-cream/85 leading-relaxed mb-6">
            Vi tilbyr moderne, stille og akustisk optimaliserte studioer som er perfekt egnet for innlesing av lydbøker, e-læringsmateriell og voicing til film og spill. Rommene er spesielt behandlet for å gi en ren, tørr og behagelig lyd.
          </p>
          <ul class="space-y-3 text-cream/85">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Lydisolerte rom med lav støybunn
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Profesjonelle kondensatormikrofoner
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Tilrettelagt for lange innlesingsøkter
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Regi og teknikerbistand tilgjengelig
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Band & Ensemble -->
  <section id="ensemble" class="py-24 px-6 scroll-mt-32">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="text-gold tracking-[0.2em] uppercase text-sm mb-3">Band & Ensemble</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Felles&shy;innspilling i stort studio</h2>
          <p class="text-cream/85 leading-relaxed mb-6">
            Vårt hovedstudio på 50 m² er designet for ensemble- og bandinnspillinger. Alle innspillingsrommene er koblet til samme kontrollrom, noe som gir fleksibilitet til å spille inn store besetninger med god separasjon og kontroll.
          </p>

          <div class="bg-dark-card border border-dark-border rounded-lg p-6 mb-6">
            <h3 class="text-gold font-semibold mb-3">Slik fungerer det</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
              <div>
                <div class="text-2xl mb-1">💬</div>
                <div class="text-xs text-cream/85 uppercase tracking-wide">Dialog</div>
              </div>
              <div>
                <div class="text-2xl mb-1">🎨</div>
                <div class="text-xs text-cream/85 uppercase tracking-wide">Kreativt</div>
              </div>
              <div>
                <div class="text-2xl mb-1">🎵</div>
                <div class="text-xs text-cream/85 uppercase tracking-wide">Materiale</div>
              </div>
              <div>
                <div class="text-2xl mb-1">🎙️</div>
                <div class="text-xs text-cream/85 uppercase tracking-wide">Innspilling</div>
              </div>
            </div>
          </div>

          <p class="text-cream/85 text-sm">
            Vi samarbeider med Nordic Film Strings og tilbyr jevnlige fellesinnspillinger for strykere.
          </p>
        </div>
        <div class="fade-in">
          <img src="/images/strings/strykeorkester-studio.jpeg" alt="Ensemble-innspilling" class="rounded-lg w-full object-cover aspect-[4/3]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-24 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-serif font-semibold text-center mb-12 fade-in">Våre studioer</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 fade-in">
        <img src="/images/studio/studio-1.jpg" alt="Studio 1" class="rounded-lg w-full h-48 object-cover" />
        <img src="/images/studio/studio-2.jpg" alt="Studio 2" class="rounded-lg w-full h-48 object-cover" />
        <img src="/images/studio/studio-3.jpg" alt="Studio 3" class="rounded-lg w-full h-48 object-cover" />
        <img src="/images/studio/produsentrommet.jpeg" alt="Produsentrommet" class="rounded-lg w-full h-48 object-cover" />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactForm
    formName="Innspilling"
    serviceType="innspilling"
    heading="Book innspilling"
    description="Fortell oss om prosjektet ditt, så finner vi den beste løsningen for deg."
  />
</Layout>
