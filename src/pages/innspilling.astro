---
import Layout from '../layouts/Layout.astro';
import Mobula from '../components/Mobula.astro';
import PasserFor from '../components/PasserFor.astro';
import SlikJobberVi from '../components/SlikJobberVi.astro';
import Faq from '../components/Faq.astro';
import ABPlayer from '../components/ABPlayer.astro';
import KundeSitater from '../components/KundeSitater.astro';
import { listReferanser, listKunder } from '../lib/content';
const referanser = await listReferanser();
const kunder = (await listKunder()).filter(k => k.tags?.some(t => ['innspilling', 'mix', 'mastering', 'vokal', 'band', 'strykere'].includes(t))).slice(0, 4);

const services = [
  {
    href: '/innspilling/singer-songwriter',
    num: '01',
    title: 'Singer-songwriter',
    intro: 'Demo, singel eller EP. For deg som skriver egne låter og vil få dem ordentlig innspilt — alene eller med band.',
    image: '/images/studio/singer-songwriter.jpeg',
    alt: 'Singer-songwriter spiller inn egen låt i studio hos Mobula Music',
  },
  {
    href: '/innspilling/vokal',
    num: '02',
    title: 'Vokalinnspilling',
    intro: 'Lead-vokal, korstemmer, solist eller klassisk vokalist. Mikrofoner og rom tilpasset din stemme.',
    image: '/images/studio/vokalinnspilling.jpeg',
    alt: 'Vokalinnspilling med profesjonell kondensatormikrofon i vokalrom',
  },
  {
    href: '/innspilling/lydbok-og-voice-over',
    num: '03',
    title: 'Lydbok & voice-over',
    intro: 'Lydbøker, e-læring, reklame og spillvoicing. Stille rom, lav støybunn, tilrettelagt for lange økter.',
    image: '/images/voice-over/voice-studio.jpg',
    alt: 'Lydbokinnleser i taleopptaksstudio med profesjonell mikrofon og regi',
  },
  {
    href: '/innspilling/band-og-ensemble',
    num: '04',
    title: 'Band & ensemble',
    intro: 'Band, korps, kor eller andre store besetninger. Hovedstudio på 50 m² med flere tilkoblede rom.',
    image: '/images/studio/fasttrack-5.jpeg',
    alt: 'Band under live-innspilling i hovedstudio på 50 m² hos Mobula Music',
  },
  {
    href: '/innspilling/strykere-og-klassisk',
    num: '05',
    title: 'Strykere & klassisk',
    intro: 'Kammerensembler, strykeorkester og klassiske besetninger. Ta del i jevnlige fellesinnspillinger for å dele kostnad.',
    image: '/images/studio/nordic-film-strings.jpg',
    alt: 'Strykeorkester under innspilling av klassisk musikk og filmmusikk',
  },
];
---

<Layout
  title="Innspillingsstudio i Lørenskog — Vokal, Band & Strykere | Mobula Music"
  description="Profesjonell innspilling for artister, singer-songwriter, band og klassiske ensembler. Akustisk optimaliserte rom, erfarne teknikere og kort vei fra Oslo og Lillestrøm."
  altLang="/en/recording"
>
  <!-- Hero -->
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(90vw,1200px)] translate-x-[28%] opacity-[0.15]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-7xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Innspilling</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-semibold leading-[1.02] mb-8 max-w-4xl">
        Fra første demo<br />til ferdig produksjon
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        Profesjonelt innspillingsstudio i Lørenskog for singer-songwriter, vokalist, band, strykere og lydbok. Kort vei fra Oslo og Lillestrøm — vi tilpasser rom, utstyr og teknikere til prosjektet ditt.
      </p>
    </div>
  </section>

  <!-- Passer for deg -->
  <PasserFor
    title="Passer for deg uansett"
    intro="Vi tar imot alt fra førstegangs-singer-songwriter til etablerte band og klassiske ensembler. Lydstudioet er bygget for at du skal føle deg trygg i rommet og fornøyd med det du går ut med."
    items={[
      'Du har aldri vært i studio før og vil prøve en økt.',
      'Du er singer-songwriter med en låt som skal gis ut.',
      'Du er vokalist, skuespiller eller innleser som trenger profesjonelt taleopptak.',
      'Du spiller i band, korps eller kor og vil spille inn sammen.',
      'Du er klassisk musiker eller komponist med behov for strykere.',
    ]}
  />

  <!-- Services grid -->
  <section class="py-28 md:py-36 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Hva vi spiller inn</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Fem områder,<br />ett studio</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Hvert område har sine egne hensyn når det kommer til mikrofoner, rom og arbeidsmåte. Klikk deg inn på det som passer.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((s) => (
          <a href={s.href} class="group fade-in">
            <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
              <img src={s.image} alt={s.alt ?? s.title} class:list={["w-full h-full transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)] group-hover:[filter:saturate(0.85)_contrast(1)_brightness(1)]", s.fit === 'contain' ? 'object-contain' : 'object-cover']} />
              <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-30 pointer-events-none"></div>
              <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
              <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
              <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
              <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">{s.num}</span>
            </div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">{s.title}</h3>
                <p class="text-cream/70 text-sm leading-relaxed max-w-xs">{s.intro}</p>
              </div>
              <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {referanser.length > 0 && (
    <section class="py-28 px-6 bg-dark-light/30">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Før / etter</p>
          <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05] mb-4">Hør forskjellen</h2>
          <p class="text-cream/70 max-w-2xl">Råopptak sammenlignet med ferdig mikset og mastret versjon. Bytt mellom variantene underveis — avspillingen holder seg på samme sted.</p>
        </div>
        <ABPlayer referanser={referanser} />
      </div>
    </section>
  )}

  {kunder.length > 0 && (
    <section class="py-28 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="mb-12 fade-in">
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Kundehistorier</p>
          <h2 class="text-4xl md:text-5xl font-serif font-semibold leading-[1.05]">Det kundene sier</h2>
        </div>
        <KundeSitater kunder={kunder} />
      </div>
    </section>
  )}

  <!-- Slik jobber vi -->
  <SlikJobberVi />

  <!-- FAQ -->
  <Faq
    label="Vanlige spørsmål"
    title="Spørsmål vi får ofte"
    items={[
      {
        q: 'Jeg har aldri vært i studio før — er det greit?',
        a: 'Ja, helt greit. Mange som kommer til oss har aldri spilt inn i studio før. Vi tar oss tid til å forklare alt, og lar deg finne roen før vi begynner.',
      },
      {
        q: 'Kan jeg spille inn uten tekniker?',
        a: 'Noen ganger, ja. For enkle vokalopptak tilbyr vi "gjør-det-selv"-tid i rommene våre til redusert timepris, hvis du har erfaring fra før. For alt annet anbefaler vi tekniker — det gir bedre resultat og tar mindre tid.',
      },
      {
        q: 'Hva koster det?',
        a: 'Avhenger av hva du skal spille inn og hvor mye tid du trenger. Se <a href="/priser" class="text-gold hover:underline">prisene våre</a> for startpakker og timespriser, eller ta kontakt så gir vi et fast tilbud.',
      },
      {
        q: 'Har dere tilgjengelighet for musikere og instrumenter jeg ikke har selv?',
        a: 'Ja. Vi har et nettverk av profesjonelle musikere vi ofte jobber med — vokalister, strykere, blåsere og rytmeseksjon. Vi tilrettelegger hvis du trenger hjelp til å finne riktige musikere for prosjektet.',
      },
      {
        q: 'Hvor mye tid trenger jeg å bestille?',
        a: 'Helt avhengig av prosjektet. En enkel vokalinnspilling av én låt kan være gjort på 2–3 timer. En full singel med band kan ta en hel dag. Vi gir deg ærlige estimater i forkant så du ikke booker for lite eller for mye.',
      },
    ]}
  />

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Book en innspilling
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        Fortell oss om prosjektet — vi svarer innen 1–2 dager med spørsmål, forslag og et fast&nbsp;tilbud.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Ta kontakt
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          920 39 045
        </a>
      </div>
    </div>
  </section>
</Layout>
