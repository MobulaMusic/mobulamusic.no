---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { geminiStudio3, storeStudio, podkastHero, vokalromForside, nordicFilmStrings, sidestudio } from '../assets/images';
import nordicFilmStringsStrings from '../assets/images/strings/nordic-film-strings.jpg';
---

<Layout
  title="Lydstudio på Østlandet — Innspilling, Podkast & Musikkproduksjon | Mobula Music"
  description="Lydstudio i Lørenskog med kort vei fra Oslo og Lillestrøm. Innspilling av vokal, band og strykere, podkastproduksjon, filmmusikk og noteproduksjon — alt under ett tak."
  altLang="/en"
>
  <!-- Hero -->
  <section class="relative h-screen min-h-[560px] md:min-h-[640px] flex items-center overflow-hidden bg-dark pt-24 md:pt-0">
    <!-- Studio photo background -->
    <div class="absolute inset-0">
      <Image
        src={geminiStudio3}
        alt=""
        widths={[800, 1200, 1600, 1920]}
        sizes="100vw"
        format="webp"
        class="w-full h-full object-cover scale-105 hero-zoom"
        style="filter: brightness(1.2);"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <!-- Warm tonal wash over the photo -->
    <div class="absolute inset-0 mix-blend-multiply" style="background: radial-gradient(ellipse at 65% 40%, rgba(40,28,18,0.35) 0%, rgba(11,26,34,0.85) 55%, rgba(7,18,23,0.95) 100%);"></div>

    <!-- Accent glows (hidden on mobile via CSS to save GPU) -->
    <div class="absolute top-[20%] right-[15%] w-[560px] h-[560px] rounded-full blur-[100px] hero-glow" style="background: rgba(255,159,61,0.18);"></div>
    <div class="absolute top-[10%] right-[5%] w-[480px] h-[480px] bg-gold/10 rounded-full blur-[100px] hero-glow"></div>
    <div class="absolute bottom-[5%] left-[5%] w-[520px] h-[520px] bg-[color:var(--color-accent-2)]/10 rounded-full blur-[100px] hero-glow"></div>

    <!-- Left fade so title stays legible -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/85 via-40% to-transparent"></div>
    <!-- Bottom fade into page -->
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-dark to-transparent"></div>

    <div class="relative z-10 px-6 md:px-12 lg:px-20 max-w-7xl mx-auto w-full">
      <p class="hero-fade hero-fade-1 font-mono text-gold tracking-[0.2em] uppercase text-sm md:text-base mb-6">Velkommen til studioet vårt i Lørenskog</p>
      <h1 class="hero-fade hero-fade-2 text-4xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.02] font-semibold mb-8 max-w-4xl">
        Rom for kreativitet<br />&amp; god lyd
      </h1>
      <p class="hero-fade hero-fade-3 text-cream/85 text-xl md:text-2xl max-w-2xl mb-12 leading-relaxed">
        Innspilling, podkast og musikkproduksjon — fra første idé til ferdig mix.<br class="hidden md:block" />Lørenskog, en kort kjøretur fra Oslo og Lillestrøm.
      </p>
      <div class="hero-fade hero-fade-4 flex flex-col sm:flex-row gap-4">
        <a href="/kontakt" class="group inline-flex items-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm rounded-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Kontakt oss
        </a>
        <a href="#tjenester" class="inline-flex items-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm rounded-sm hover:border-gold hover:text-gold hover:shadow-[0_0_0_1px_var(--color-gold),0_0_40px_-10px_var(--color-gold)] transition-all">
          Våre tjenester
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Services -->
  <section id="tjenester" class="relative py-28 md:py-36 px-6 overflow-hidden">
    <div class="relative max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — Våre tjenester</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Hva kan vi hjelpe<br />deg med?</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Innspilling, podkast og originalmusikk — tre kjerneområder under ett tak i Lørenskog. Fra første idé til ferdig mix og mastering.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <!-- Innspilling -->
        <a href="/innspilling" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
            <Image src={storeStudio} alt="Hovedstudioet til Mobula Music — stor innspillingssal for band, ensemble og vokalist" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.85)_contrast(0.98)_brightness(1)] group-hover:[filter:saturate(1)_contrast(1)_brightness(1.05)]" loading="lazy" />
            <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-15 pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">01</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Innspilling</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Singer-songwriter, vokal, band, strykere, lydbok og voice-over. Fra første demo til ferdig produksjon.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>

        <!-- Podkast -->
        <a href="/podkast" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
            <Image src={podkastHero} alt="Podkaststudio i Lørenskog med profesjonelle mikrofoner og kamera-oppsett" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.85)_contrast(0.98)_brightness(1)] group-hover:[filter:saturate(1)_contrast(1)_brightness(1.05)]" loading="lazy" />
            <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-15 pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">02</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Podkast</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Innspilling, klipping, lyddesign, originalmusikk og opplæring — alt under ett tak.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>

        <!-- Musikk -->
        <a href="/musikk" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
            <Image src={nordicFilmStringsStrings} alt="Nordic Film Strings under innspilling av filmmusikk hos Mobula Music" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.85)_contrast(0.98)_brightness(1)] group-hover:[filter:saturate(1)_contrast(1)_brightness(1.05)]" loading="lazy" />
            <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-15 pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">03</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Musikk</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Skreddersydd musikk til film, TV, scenekunst, reklame og produsering av låtprosjekter.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Mobula -->
  <section class="py-28 md:py-36 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">02 — Hvorfor Mobula</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Et studio bygget<br />for kvalitet</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Akustisk optimaliserte innspillingsrom, profesjonelt utstyr og erfarne teknikere — plassert i Lørenskog, bare minutter fra Oslo sentrum med tog. Teknisk håndverk kombinert med kunstnerisk forståelse.
        </p>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-2 md:grid-cols-4 border-y border-cream/10 mb-16 fade-in">
        <div class="py-8 px-4 md:px-6 border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">50m²</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Hovedstudio</div>
        </div>
        <div class="py-8 px-4 md:px-6 md:border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">3</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Innspillingsrom</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-r border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">15 min</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Fra Oslo</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">Gratis</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Parkering</div>
        </div>
      </div>

      <!-- Asymmetric image grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 fade-in">
        <div class="md:col-span-2 md:row-span-2 relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <Image src={nordicFilmStrings} alt="Strykere fra Nordic Film Strings spiller inn filmmusikk i Mobulas hovedstudio" widths={[400, 800, 1200]} sizes="(min-width: 768px) 66vw, 100vw" format="webp" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)]" loading="lazy" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-4 left-4 font-mono text-white text-xs tracking-widest uppercase">Hovedstudio</span>
        </div>
        <div class="relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <Image src={sidestudio} alt="Sidestudio for mindre innspillinger og lydopptak hos Mobula Music" widths={[400, 800]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)]" loading="lazy" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-3 left-3 font-mono text-white text-[10px] tracking-widest uppercase">Sidestudio</span>
        </div>
        <div class="relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <Image src={vokalromForside} alt="Vokalist spiller inn i akustisk optimalisert vokalrom hos Mobula Music" widths={[400, 800]} sizes="(min-width: 768px) 33vw, 100vw" format="webp" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)]" loading="lazy" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-3 left-3 font-mono text-white text-[10px] tracking-widest uppercase">Vokalrom</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Klar for å komme i gang?
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        Enten du trenger innspilling, podkast eller skreddersydd musikk — vi hjelper deg fra idé til ferdig resultat.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Ta kontakt
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          920 39 045
        </a>
      </div>
    </div>
  </section>
</Layout>
