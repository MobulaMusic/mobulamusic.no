---
import Layout from '../layouts/Layout.astro';
import Mobula from '../components/Mobula.astro';
---

<Layout
  title="Mobula Music AS | Lydstudio i Lørenskog | Innspilling, Podkast, Komposisjon"
  description="Mobula Music AS. Lydstudio for innspilling av musikk og podkast i Lørenskog. Produksjon av musikk for film og TV. Kort vei fra Oslo og Lillestrøm."
>
  <!-- Hero -->
  <section class="relative h-screen min-h-[640px] flex items-center overflow-hidden bg-dark">
    <!-- Deep teal radial base -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 70% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>

    <!-- Accent glows -->
    <div class="absolute top-[15%] right-[10%] w-[640px] h-[640px] bg-gold/15 rounded-full blur-[160px] hero-glow"></div>
    <div class="absolute bottom-[5%] left-[5%] w-[520px] h-[520px] bg-[color:var(--color-accent-2)]/12 rounded-full blur-[140px] hero-glow"></div>

    <!-- Large mobula silhouette as hero visual — dramatic bleed -->
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(120vw,1800px)] translate-x-[28%] opacity-[0.18] hero-zoom" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <!-- Left fade so title stays legible -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/70 to-transparent"></div>

    <div class="relative z-10 px-6 md:px-12 lg:px-20 max-w-7xl mx-auto w-full">
      <p class="hero-fade hero-fade-1 font-mono text-gold tracking-[0.2em] uppercase text-sm md:text-base mb-6">Ditt studio i Lørenskog</p>
      <h1 class="hero-fade hero-fade-2 text-4xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.02] font-semibold mb-8 max-w-4xl">
        Rom for kreativitet<br />&amp; god lyd
      </h1>
      <p class="hero-fade hero-fade-3 text-cream/80 text-xl md:text-2xl max-w-2xl mb-12 leading-relaxed">
        Innspilling, podkast og musikkproduksjon.<br class="hidden md:block" />Kort vei fra Oslo og Lillestrøm.
      </p>
      <div class="hero-fade hero-fade-4 flex flex-col sm:flex-row gap-4">
        <a href="/kontakt" class="group inline-flex items-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm rounded-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Kontakt oss
        </a>
        <a href="#tjenester" class="inline-flex items-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm rounded-sm hover:border-gold hover:text-gold hover:shadow-[0_0_0_1px_var(--color-gold),0_0_40px_-10px_var(--color-gold)] transition-all">
          Våre tjenester
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Services -->
  <section id="tjenester" class="relative py-28 md:py-36 px-6 overflow-hidden">
    <div class="relative max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">01 — Våre tjenester</p>
          <h2 class="text-4xl md:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Hva kan vi hjelpe<br />deg med?</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Fra første idé til ferdig mix. Tre kjerneområder — ett studio, samme kvalitet.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <!-- Innspilling -->
        <a href="/innspilling" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/studio/store-studio.jpeg" alt="Innspillingsstudio" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">01</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Innspilling</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Vokal, lydbok, voice-over, band og ensemble. Profesjonelle fasiliteter med erfarne teknikere.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>

        <!-- Podkast -->
        <a href="/podkast" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/podcast/podkast-studio.jpeg" alt="Podkaststudio" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">02</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Podkast</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Profesjonell podkastinnspilling og opplæring. Lyd og bilde i topp kvalitet.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>

        <!-- Komposisjon -->
        <a href="/musikk" class="group fade-in">
          <div class="relative overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/strings/nordic-film-strings.jpg" alt="Orkesterinnspilling" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 group-hover:ring-gold/60 transition-all duration-500"></div>
            <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">03</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2 group-hover:text-gold transition-colors">Komposisjon</h3>
              <p class="text-cream/70 text-sm leading-relaxed max-w-xs">Skreddersydd musikk til film, TV, reklame og podkast. Fra idé til ferdig produksjon.</p>
            </div>
            <span class="shrink-0 text-gold translate-y-1 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Mobula -->
  <section class="py-28 md:py-36 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">02 — Hvorfor Mobula</p>
          <h2 class="text-4xl md:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Et studio bygget<br />for kvalitet</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Akustisk optimalisert, profesjonelt utstyrt, og plassert minutter fra Oslo sentrum. Vi kombinerer teknisk håndverk med kunstnerisk forståelse.
        </p>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-2 md:grid-cols-4 border-y border-cream/10 mb-16 fade-in">
        <div class="py-8 px-4 md:px-6 border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">50m²</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Hovedstudio</div>
        </div>
        <div class="py-8 px-4 md:px-6 md:border-r border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">4</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Innspillingsrom</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-r border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">15 min</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Fra Oslo</div>
        </div>
        <div class="py-8 px-4 md:px-6 border-t md:border-t-0 border-cream/10">
          <div class="font-serif text-gold text-4xl md:text-5xl font-semibold mb-2">Gratis</div>
          <div class="font-mono text-cream/60 text-xs tracking-widest uppercase">Parkering</div>
        </div>
      </div>

      <!-- Asymmetric image grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 fade-in">
        <div class="md:col-span-2 md:row-span-2 relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <img src="/images/studio/nordic-film-strings.jpg" alt="Hovedstudio" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-4 left-4 font-mono text-white text-xs tracking-widest uppercase">Hovedstudio</span>
        </div>
        <div class="relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <img src="/images/studio/sidestudio.jpeg" alt="Sidestudio" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-3 left-3 font-mono text-white text-[10px] tracking-widest uppercase">Sidestudio</span>
        </div>
        <div class="relative overflow-hidden aspect-[4/3] md:aspect-auto group">
          <img src="/images/studio/vocal-recording.jpg" alt="Vokalrom" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
          <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/90 to-transparent pointer-events-none"></div>
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
          <span class="absolute bottom-3 left-3 font-mono text-white text-[10px] tracking-widest uppercase">Vokalrom</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Klar for å komme i gang?</h2>
      <p class="text-cream/85 text-lg mb-10">
        Enten du trenger innspilling, podkastproduksjon eller skreddersydd musikk — vi hjelper deg fra idé til ferdig resultat.
      </p>
      <a href="/kontakt" class="inline-block px-10 py-4 bg-gold text-dark font-semibold rounded tracking-wide uppercase hover:bg-gold-light transition-colors">
        Ta kontakt
      </a>
    </div>
  </section>
</Layout>
