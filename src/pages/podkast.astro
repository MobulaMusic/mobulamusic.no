---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Podkast | Innspilling og opplæring | Mobula Music AS"
  description="Profesjonell podkastinnspilling med lyd og bilde i toppkvalitet. Vi tilbyr også podkast-opplæring slik at du kan komme i gang på riktig måte."
  ogImage="/images/podcast/podkast-studio.jpeg"
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 px-6">
    <div class="absolute inset-0 z-0">
      <img src="/images/podcast/podkast-panorama.jpeg" alt="Podkaststudio" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-dark/80 via-dark/70 to-dark"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-gold tracking-[0.2em] uppercase text-sm mb-4">Podkast</p>
      <h1 class="text-4xl md:text-6xl font-serif font-bold mb-6">Spill inn din podkast hos oss</h1>
      <p class="text-cream/70 text-lg max-w-2xl mx-auto">
        En god podkast krever godt innhold, men ikke minst god kvalitet på lyd og bilde. Vi hjelper deg med begge deler.
      </p>
    </div>
  </section>

  <!-- Innspilling i studio -->
  <section class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="text-gold tracking-[0.2em] uppercase text-sm mb-3">Innspilling</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Profesjonelt podkaststudio</h2>
          <p class="text-cream/70 leading-relaxed mb-6">
            Lyttere blir stadig mer kresne og forlater raskt podkaster som ikke er behagelige å høre på. Hos oss får du et ferdig oppsatt studio med profesjonelle mikrofoner, kameraer og belysning — klar til innspilling.
          </p>

          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-lg">
              <div class="w-10 h-10 bg-gold/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
              </div>
              <div>
                <h3 class="text-cream font-medium mb-1">Profesjonell lyd</h3>
                <p class="text-cream/60 text-sm">Akustisk behandlet rom med topp mikrofoner og miksepult for krystallklar lyd.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-lg">
              <div class="w-10 h-10 bg-gold/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <h3 class="text-cream font-medium mb-1">Videoopptak</h3>
                <p class="text-cream/60 text-sm">Flerkamera-oppsett med profesjonell belysning for videopodkast.</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-lg">
              <div class="w-10 h-10 bg-gold/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <h3 class="text-cream font-medium mb-1">Ferdig oppsatt</h3>
                <p class="text-cream/60 text-sm">Kom inn, sett deg ned og start innspillingen. Vi tar oss av det tekniske.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="fade-in">
          <img src="/images/podcast/podkast-studio.jpeg" alt="Podkaststudio" class="rounded-lg w-full object-cover aspect-[4/3]" />
        </div>
      </div>
    </div>
  </section>

  <!-- Opplæring -->
  <section class="py-20 px-6 bg-dark-light">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 fade-in">
          <img src="/images/podcast/podkast-2.jpeg" alt="Podkast-opplæring" class="rounded-lg w-full object-cover aspect-[4/3]" />
        </div>
        <div class="order-1 lg:order-2 fade-in">
          <p class="text-gold tracking-[0.2em] uppercase text-sm mb-3">Opplæring</p>
          <h2 class="text-3xl md:text-4xl font-serif font-semibold mb-6">Lær å lage profesjonell podkast</h2>
          <p class="text-cream/70 leading-relaxed mb-6">
            Vil du starte egen podkast, men vet ikke hvor du skal begynne? Vi tilbyr opplæring som tar deg gjennom hele prosessen — fra konseptutvikling og teknisk oppsett til redigering og publisering.
          </p>

          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-cream/70">Konseptutvikling og planlegging</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-cream/70">Teknisk oppsett og utstyr</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-cream/70">Innspillingsteknikk og intervjumetoder</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-cream/70">Redigering og etterarbeid</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-cream/70">Publisering og distribusjon</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA image strip -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-3 gap-4 fade-in">
        <img src="/images/podcast/pod-pic.jpeg" alt="Podkast innspilling" class="rounded-lg w-full h-64 object-cover" />
        <img src="/images/podcast/podkast-panorama.jpeg" alt="Podkaststudio panorama" class="rounded-lg w-full h-64 object-cover" />
        <img src="/images/podcast/podkast-2.jpeg" alt="Podkast produksjon" class="rounded-lg w-full h-64 object-cover" />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactForm
    formName="Podkast"
    serviceType="podkast"
    heading="Kom i gang med podkast"
    description="Fortell oss om podkast-prosjektet ditt, så hjelper vi deg videre."
  />
</Layout>
