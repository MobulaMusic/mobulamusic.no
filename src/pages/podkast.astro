---
import Layout from '../layouts/Layout.astro';
import Mobula from '../components/Mobula.astro';
import PasserFor from '../components/PasserFor.astro';
import SlikJobberVi from '../components/SlikJobberVi.astro';
import Faq from '../components/Faq.astro';

const services = [
  {
    num: '01',
    title: 'Innspilling',
    intro: 'Lyd og bilde i samme studio. Profesjonelle mikrofoner, flerkamera-oppsett og tekniker — du kan fokusere på samtalen.',
    image: '/images/podcast/podkast-studio.jpeg',
    alt: 'Podkastinnspilling med profesjonell mikrofon og videooppsett hos Mobula Music',
  },
  {
    num: '02',
    title: 'Klipping & redigering',
    intro: 'Vi tar opptaket og gjør det ferdig. Tonsetting, klipping av hum, pauser og feilstart, og leveranse i ditt foretrukne format.',
    image: '/images/podcast/klipping.jpeg',
    alt: 'Podkastredigering i DAW med lydspor og klipping',
  },
  {
    num: '03',
    title: 'Lyddesign',
    intro: 'Intro, outro, overganger og lydlandskap som gir podkasten din en egen identitet.',
    image: '/images/podcast/lyddesign.jpeg',
    alt: 'Lyddesign og lydlandskap for podkastproduksjon',
  },
  {
    num: '04',
    title: 'Originalmusikk',
    intro: 'Skreddersydd vignett, jingles og bakgrunnsmusikk komponert spesielt for serien din. Du eier musikken.',
    image: '/images/podcast/originalmusikk.png',
    alt: 'Komposisjon av originalmusikk og vignett til podkast',
  },
  {
    num: '05',
    title: 'Opplæring',
    intro: 'Vil du lage podkast selv? Vi tar deg gjennom konsept, teknikk, intervjumetoder, redigering og publisering.',
    image: '/images/podcast/opplaring.jpeg',
    alt: 'Podkastopplæring og kurs for nye podkastverter',
  },
];
---

<Layout
  title="Podkaststudio i Lørenskog — Innspilling, Klipping & Produksjon | Mobula Music"
  description="Komplett podkasttilbud: innspilling med lyd og video, klipping, lyddesign, originalmusikk og opplæring. Alt under ett tak, kort vei fra Oslo og Lillestrøm."
>
  <!-- Hero -->
  <section class="relative pt-40 pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(90vw,1200px)] translate-x-[28%] opacity-[0.15]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-7xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Podkast</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-semibold leading-[1.02] mb-8 max-w-4xl">
        Hele veien fra<br />idé til lytter
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed">
        Innspilling, klipping, lyddesign, musikk og opplæring — alt under ett tak. Du kommer med samtalen, vi tar oss av resten.
      </p>
    </div>
  </section>

  <!-- Passer for deg -->
  <PasserFor
    title="Passer for deg uansett"
    intro="Vi spiller inn alt fra den aller første episoden i en hobbyserie til ferdige produksjoner for podkastselskap."
    items={[
      'Du har en god idé til en podkast og vil gjøre den ordentlig fra start.',
      'Du har allerede en serie og trenger fast innspillingssted.',
      'Du er bedrift som vil starte podkast som del av merkevaren.',
      'Du er forfatter, foredragsholder eller fagperson som vil dele kunnskap.',
      'Du vil lære å lage podkast selv — fra A til Å.',
    ]}
  />

  <!-- Services grid -->
  <section class="py-28 md:py-36 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 gap-6 fade-in">
        <div>
          <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Hva vi tilbyr</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold leading-[1.05] max-w-2xl">Alt du trenger,<br />på ett sted</h2>
        </div>
        <p class="text-cream/70 text-base md:text-lg max-w-md leading-relaxed">
          Velg én tjeneste eller hele pakka — vi tilpasser oss prosjektet og budsjettet ditt.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((s) => (
          <div class="group fade-in">
            <div class="relative overflow-hidden aspect-[4/3] mb-5 bg-dark">
              <img src={s.image} alt={s.alt ?? s.title} class="w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.04] [filter:saturate(0.72)_contrast(0.95)_brightness(0.92)] group-hover:[filter:saturate(0.85)_contrast(1)_brightness(1)]" />
              <div class="absolute inset-0 bg-[#0b1a22] mix-blend-multiply opacity-30 pointer-events-none"></div>
              <div class="absolute inset-0 bg-gradient-to-tr from-[#7af0c8]/10 via-transparent to-[#c9a2ff]/10 mix-blend-overlay pointer-events-none"></div>
              <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-dark/80 to-transparent pointer-events-none"></div>
              <div class="absolute inset-0 ring-1 ring-inset ring-cream/10"></div>
              <span class="absolute top-4 left-4 font-mono text-gold text-xs tracking-widest">{s.num}</span>
            </div>
            <div>
              <h3 class="text-2xl md:text-3xl font-serif font-semibold mb-2">{s.title}</h3>
              <p class="text-cream/70 text-sm leading-relaxed">{s.intro}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Slik jobber vi -->
  <SlikJobberVi
    title="Slik kommer du i gang"
    intro="Du trenger ikke ha alt klart fra start. Vi hjelper deg gjennom hele prosessen."
    steps={[
      {
        title: 'Idé & samtale',
        body: 'Vi snakker om konseptet ditt — målgruppe, tema, format og frekvens. Du får forslag, vi gir et fast tilbud.',
      },
      {
        title: 'Studio & innspilling',
        body: 'Du kommer til studio, tekniker setter opp alt, og dere kan starte direkte. Lyd og bilde i toppkvalitet, hver gang.',
      },
      {
        title: 'Klipping & levering',
        body: 'Vi klipper, mikser og legger til musikk og lyddesign. Du får ferdige episoder klare for opplasting til Spotify eller andre podkasttjenester.',
      },
    ]}
  />

  <!-- FAQ -->
  <Faq
    label="Vanlige spørsmål"
    title="Spørsmål vi får ofte"
    items={[
      {
        q: 'Jeg har aldri spilt inn podkast før — kan jeg fortsatt starte?',
        a: 'Ja, definitivt. Mange av kundene våre starter sin første podkast hos oss. Vi tar oss tid til å forklare alt, og du trenger verken teknisk kunnskap eller egen erfaring foran mikrofonen.',
      },
      {
        q: 'Hva koster det?',
        a: 'Avhenger av hvor mye du trenger hjelp til. Ren innspilling i studioet vårt er rimeligere enn en full pakke med klipping, lyddesign og musikk. Se <a href="/priser" class="text-gold hover:underline">prisene våre</a> for indikasjon, eller ta kontakt for et fast tilbud.',
      },
      {
        q: 'Kan jeg ta opp video samtidig?',
        a: 'Ja. Vi har flerkamera-oppsett med profesjonell belysning, så du kan enkelt lage videopodkast for YouTube samtidig som du spiller inn lyd.',
      },
      {
        q: 'Eier jeg podkasten min?',
        a: 'Ja, alltid. Du eier opptakene og rettighetene til alt vi lager til deg — også musikk og lyddesign. Vi kan også hjelpe deg med publisering hvis du ikke vil gjøre det selv.',
      },
      {
        q: 'Hvor mye tid trenger jeg å booke?',
        a: 'En enkel innspilling med to gjester på 45 minutter går unna på en time eller to inkludert oppsett. Lengre formater eller flere gjester tar mer tid. Vi gir deg ærlig estimat i forkant.',
      },
      {
        q: 'Kan dere hjelpe meg å komme i gang fra null?',
        a: 'Ja. Vi tilbyr <strong class="text-cream">opplæring</strong> som tar deg gjennom hele prosessen — fra idé og konseptutvikling til teknisk oppsett, intervjumetoder, redigering og publisering.',
      },
    ]}
  />

  <!-- CTA -->
  <section class="py-28 px-6">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <h2 class="text-3xl md:text-5xl font-serif font-semibold mb-6 leading-tight">
        Klar for å spille inn?
      </h2>
      <p class="text-cream/80 text-lg mb-10 max-w-xl mx-auto">
        Fortell oss om podkast-prosjektet ditt — vi svarer innen 1–2 dager med spørsmål, forslag og et fast&nbsp;tilbud.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Ta kontakt
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          920 39 045
        </a>
      </div>
    </div>
  </section>
</Layout>
