---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import FilmEditor from '../../../components/admin/FilmEditor.astro';
import { getFilm } from '../../../lib/content';

const { slug } = Astro.params;
const film = await getFilm(slug!);
if (!film) return Astro.redirect('/admin/film');
---
<AdminLayout title={`Rediger: ${film.title}`}>
  <FilmEditor mode="update" film={film} />
</AdminLayout>
