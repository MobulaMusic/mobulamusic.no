---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const cards = [
  { href: '/admin/posts', title: 'Blogg', desc: 'Opprett og rediger bloggposter' },
  { href: '/admin/images', title: 'Bilder', desc: 'Last opp og administrer bilder' },
  { href: '/admin/texts', title: 'Tekster', desc: 'Rediger tekstinnhold på siden' },
  { href: '/admin/forms', title: 'Skjemaer', desc: 'Se innsendte skjemaer' },
];
---
<AdminLayout title="Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {cards.map(c => (
      <a href={c.href} class="block p-6 rounded-xl border border-neutral-800 hover:border-neutral-600 hover:bg-neutral-900 transition">
        <h3 class="text-lg font-semibold">{c.title}</h3>
        <p class="text-sm text-neutral-400 mt-1">{c.desc}</p>
      </a>
    ))}
  </div>
</AdminLayout>
