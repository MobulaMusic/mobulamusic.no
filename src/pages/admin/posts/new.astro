---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
const today = new Date().toISOString().slice(0, 10);
---
<AdminLayout title="Nytt bloggpost">
  <form method="POST" action="/api/admin/posts" class="space-y-4 max-w-3xl">
    <input type="hidden" name="mode" value="create" />
    <label class="block">
      <span class="text-sm text-neutral-400">Tittel</span>
      <input name="title" required class="mt-1 w-full rounded bg-neutral-800 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm text-neutral-400">Beskrivelse</span>
      <input name="description" required class="mt-1 w-full rounded bg-neutral-800 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm text-neutral-400">Dato</span>
      <input name="date" type="date" value={today} required class="mt-1 rounded bg-neutral-800 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm text-neutral-400">Bilde (URL)</span>
      <input name="image" class="mt-1 w-full rounded bg-neutral-800 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm text-neutral-400">Tags (kommaseparert)</span>
      <input name="tags" class="mt-1 w-full rounded bg-neutral-800 px-3 py-2" />
    </label>
    <label class="block">
      <span class="text-sm text-neutral-400">Innhold (markdown)</span>
      <textarea name="body" rows="16" required class="mt-1 w-full rounded bg-neutral-800 px-3 py-2 font-mono text-sm"></textarea>
    </label>
    <div class="flex gap-2">
      <button class="rounded bg-white text-black px-4 py-2 text-sm font-medium">Lagre</button>
      <a href="/admin/posts" class="rounded border border-neutral-700 px-4 py-2 text-sm">Avbryt</a>
    </div>
  </form>
</AdminLayout>
