---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import KundeEditor from '../../../components/admin/KundeEditor.astro';
import { getKunde } from '../../../lib/content';

const { slug } = Astro.params;
const kunde = await getKunde(slug!);
if (!kunde) return Astro.redirect('/admin/kunder');
---
<AdminLayout title={`Rediger: ${kunde.kunde}`}>
  <KundeEditor mode="update" kunde={kunde} />
</AdminLayout>
