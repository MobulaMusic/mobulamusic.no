---
import Layout from '../layouts/Layout.astro';
import Mobula from '../components/Mobula.astro';
import ContactForm from '../components/ContactForm.astro';
import Faq from '../components/Faq.astro';
---

<Layout
  title="Kontakt Mobula Music — Ring, E-post eller Skjema | Lydstudio Lørenskog"
  description="Ta kontakt for innspilling, podkast eller musikkproduksjon. Ring 920 39 045 eller send oss en melding — vi svarer innen 1–2 dager med fast tilbud."
  altLang="/en/contact"
>
  <!-- Hero -->
  <section class="relative pt-32 md:pt-40 pb-20 md:pb-24 px-6 overflow-hidden bg-dark">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 40%, #10242f 0%, #0b1a22 60%, #071217 100%);"></div>
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-gold/10 rounded-full blur-[140px] hero-glow"></div>
    <div class="absolute inset-y-0 right-0 flex items-center pointer-events-none">
      <Mobula class="w-[min(90vw,1200px)] translate-x-[28%] opacity-[0.15]" c1="#7af0c8" c2="#7af0c8" c3="#7af0c8" />
    </div>

    <div class="relative max-w-5xl mx-auto">
      <p class="font-mono text-gold tracking-[0.2em] uppercase text-sm mb-6">Kontakt</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-serif font-semibold leading-[1.02] mb-8 max-w-4xl">
        Kontakt Mobula Music
      </h1>
      <p class="text-cream/80 text-xl md:text-2xl max-w-2xl leading-relaxed mb-10">
        Fortell oss om prosjektet ditt — stort eller lite. Vi svarer innen 1–2 dager med spørsmål, forslag og et fast tilbud.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#skjema" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gold text-dark font-semibold tracking-wide uppercase text-sm hover:bg-gold-light transition-colors">
          <span class="w-2 h-2 rounded-full bg-[#ff9f3d] bpm-pulse"></span>
          Send forespørsel
        </a>
        <a href="tel:+4792039045" class="inline-flex items-center justify-center px-8 py-4 border border-cream/20 text-cream tracking-wide uppercase text-sm hover:border-gold hover:text-gold transition-all">
          Ring 920 39 045
        </a>
      </div>
    </div>
  </section>

  <!-- Fordeler -->
  <section class="py-16 px-6 border-b border-dark-border/40">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 fade-in">
        {[
          ['Svar innen 1–2 dager', 'Vi leser hver henvendelse og svarer personlig.'],
          ['Fast pris før oppstart', 'Du vet hva det koster — ingen overraskelser.'],
          ['10+ års erfaring', 'Erfarne teknikere og komponister.'],
          ['15 min fra Oslo S', 'Gratis parkering, kort vei fra Lillestrøm.'],
        ].map(([title, desc]) => (
          <div class="flex gap-3 items-start">
            <span class="text-gold text-lg leading-none mt-0.5">✓</span>
            <div>
              <p class="font-semibold text-sm mb-1">{title}</p>
              <p class="text-cream/60 text-sm">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kontaktinfo -->
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-y border-cream/10 fade-in">
        <!-- Telefon -->
        <div class="py-10 px-6 md:px-8 md:border-r border-cream/10">
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-4">Telefon</p>
          <p class="font-serif text-2xl md:text-3xl font-semibold mb-2">
            <a href="tel:+4792039045" class="hover:text-gold transition-colors">920 39 045</a>
          </p>
          <p class="text-cream/50 text-sm mb-4">Haakon</p>
          <p class="font-serif text-2xl md:text-3xl font-semibold mb-2">
            <a href="tel:+4792466150" class="hover:text-gold transition-colors">924 66 150</a>
          </p>
          <p class="text-cream/50 text-sm">Olai</p>
        </div>

        <!-- E-post -->
        <div class="py-10 px-6 md:px-8 md:border-r border-t md:border-t-0 border-cream/10">
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-4">E-post</p>
          <p class="font-serif text-xl md:text-2xl font-semibold break-words">
            <a href="mailto:post@mobulamusic.com" class="hover:text-gold transition-colors">post@mobulamusic.com</a>
          </p>
          <p class="text-cream/60 text-sm mt-4 leading-relaxed">
            Send oss gjerne en beskrivelse, et DAW-prosjekt, en demo — eller bare en idé.
          </p>
        </div>

        <!-- Adresse -->
        <div class="py-10 px-6 md:px-8 border-t md:border-t-0 border-cream/10">
          <p class="font-mono text-gold text-xs tracking-widest uppercase mb-4">Adresse</p>
          <p class="font-serif text-xl md:text-2xl font-semibold leading-tight mb-2">
            Fjellhammerveien 52<br />1472 Fjellhamar
          </p>
          <p class="text-cream/60 text-sm mt-4 leading-relaxed">
            3 min fra Fjellhamar stasjon<br />Gratis parkering
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="skjema" class="pb-28 px-6 scroll-mt-24">
    <div class="max-w-3xl mx-auto fade-in">
      <div class="mb-12">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Skjema</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05] mb-4">Eller send oss en melding</h2>
        <p class="text-cream/70 text-base md:text-lg max-w-2xl leading-relaxed">
          Jo mer du forteller oss, jo bedre tilbud får du tilbake. Men du trenger ikke ha alt klart — vi hjelper deg gjerne med å finne ut hva du faktisk trenger.
        </p>
      </div>

      <ContactForm
        formName="Kontaktskjema"
        showServiceDropdown={true}
        heading=""
        description=""
      />
    </div>
  </section>

  <Faq
    title="Vanlige spørsmål"
    items={[
      {
        q: 'Hva skjer etter at jeg sender skjemaet?',
        a: 'Vi leser henvendelsen og svarer innen 1–2 dager med oppfølgingsspørsmål, forslag til opplegg og et fast tilbud. Når du godtar, finner vi en dato som passer.',
      },
      {
        q: 'Hva koster det?',
        a: 'Se <a href="/priser" class="text-gold hover:underline">prisene våre</a> for full oversikt. Du får alltid et fast tilbud før vi starter.',
      },
      {
        q: 'Kan jeg komme innom først for å se studioet?',
        a: 'Ja. Send oss en melding så avtaler vi et tidspunkt — du er velkommen til å stikke innom og se rommene før du booker.',
      },
      {
        q: 'Kan jeg ringe direkte?',
        a: 'Ja, ring 920 39 045 (Haakon) eller 924 66 150 (Olai). Vi svarer helst i kontortid, men kan ringe tilbake om vi er opptatt.',
      },
    ]}
  />

  <!-- Map -->
  <section class="pb-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 fade-in">
        <p class="font-mono text-gold tracking-[0.15em] uppercase text-xs mb-4">Slik finner du oss</p>
        <h2 class="text-3xl md:text-4xl font-serif font-semibold leading-[1.05]">Fjellhammerveien 52</h2>
      </div>
      <div class="relative overflow-hidden h-96 md:h-[500px] ring-1 ring-inset ring-cream/10 fade-in">
        <iframe
          src="https://maps.google.com/maps?q=Mobula+Music+AS&t=&z=16&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0; filter: grayscale(0.5) contrast(0.95);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mobula Music lokasjon"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
